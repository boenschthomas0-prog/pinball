Sub ResetSewerTime
	if bMidnightMadnessMode Then Exit Sub
	SewerCountDown = nSewerTime(CurrentPlayer)

	If SewerCountDown > 239 Then
		nSewerMin = 4
		nSewerSec = SewerCountDown mod 60
	Elseif SewerCountDown > 179 Then 
		nSewerMin = 3
		nSewerSec = SewerCountDown mod 60
	Elseif SewerCountDown > 119 Then 
		nSewerMin = 2
		nSewerSec = SewerCountDown mod 60
	Elseif SewerCountDown > 59 Then 
		nSewerMin = 1
		nSewerSec = SewerCountDown mod 60
	Else
		nSewerMin = ""
		nSewerSec = SewerCountDown mod 60
	End If

	DisplaySewerTime
End Sub


