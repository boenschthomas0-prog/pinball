Sub AdvanceDT
	SkillTargetLocation = SkillTargetLocation + 1
	if SkillTargetLocation > 4 Then SkillTargetLocation = 1
'Debug.print "Skill Target Adv:" &SkillTargetLocation

	Select Case SkillTargetLocation
		Case 1
			if DroppedTargets(4) = 1 Then DTDrop 4
			ClearDTLights
			PuPlayer.playevent pDMD,"Skillshot","SkillRainValue.mp4",nPupVideoVolume,60,1,0,""
			SolDT1 True
		Case 2
			if DroppedTargets(1) = 1 Then DTDrop 1
			ClearDTLights
			PuPlayer.playevent pDMD,"Skillshot","SkillThunderValue.mp4",nPupVideoVolume,60,1,0,""
			SolDT2 True
		Case 3
			if DroppedTargets(2) = 1 Then DTDrop 2
			ClearDTLights
			PuPlayer.playevent pDMD,"Skillshot","SkillLightningValue.mp4",nPupVideoVolume,60,1,0,""
			SolDT3 True
		Case 4
			if DroppedTargets(3) = 1 Then DTDrop 3
			ClearDTLights
			PuPlayer.playevent pDMD,"Skillshot","SkillLopanValue.mp4",nPupVideoVolume,60,1,0,""
			SolDT4 True
	End Select


End Sub

Sub ReverseDT
	SkillTargetLocation = SkillTargetLocation - 1
	if SkillTargetLocation < 1 Then SkillTargetLocation = 4
'	debug.print "SkillTargetLocation Rev: " &SkillTargetLocation
	Select Case SkillTargetLocation
		Case 1
			if DroppedTargets(2) = 1 Then DTDrop 2
			ClearDTLights
			PuPlayer.playevent pDMD,"Skillshot","SkillRainValue.mp4",nPupVideoVolume,60,1,0,""
			SolDT1 True
		Case 2
			if DroppedTargets(3) = 1 Then DTDrop 3
			ClearDTLights
			PuPlayer.playevent pDMD,"Skillshot","SkillThunderValue.mp4",nPupVideoVolume,60,1,0,""
			SolDT2 True
		Case 3
			if DroppedTargets(4) = 1 Then DTDrop 4
			ClearDTLights
			PuPlayer.playevent pDMD,"Skillshot","SkillLightningValue.mp4",nPupVideoVolume,60,1,0,""
			SolDT3 True
		Case 4
			if DroppedTargets(1) = 1 Then DTDrop 1
			ClearDTLights
			PuPlayer.playevent pDMD,"Skillshot","SkillLopanValue.mp4",nPupVideoVolume,60,1,0,""
			SolDT4 True
	End Select

End Sub

Sub ReturnJackTargets

	DroppedTargets(1) = DTJ
	DroppedTargets(2) = DTA
	DroppedTargets(3) = DTC
	DroppedTargets(4) = DTK

	if DroppedTargets(1) = 1 Then DTDrop 1
	if DroppedTargets(2) = 1 Then DTDrop 2
	if DroppedTargets(3) = 1 Then DTDrop 3
	if DroppedTargets(4) = 1 Then DTDrop 4

	if DroppedTargets(1) = 0 Then DTRaise 1
	if DroppedTargets(2) = 0 Then DTRaise 2
	if DroppedTargets(3) = 0 Then DTRaise 3
	if DroppedTargets(4) = 0 Then DTRaise 4

End Sub


