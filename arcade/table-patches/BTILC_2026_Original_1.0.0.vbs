Sub PortalTimer_Timer()

    ' Portal animation
    portal.ImageA = ES_Frames(ES_Pos)
    ES_Pos = ES_Pos + 1
    If ES_Pos > UBound(ES_Frames) Then ES_Pos = 0

    ' Countdown timers
    ES_TimeLeft = ES_TimeLeft - PortalTimer.Interval
    MagLightTimeLeft = MagLightTimeLeft - PortalTimer.Interval

    ' Stop maglight blink
    If MagLightTimeLeft <= 0 Then
        maglight.State = 0
    End If

    ' Stop portal
    If ES_TimeLeft <= 0 Then
        PortalTimer.Enabled = False
        portal.Visible = False
        ES_Running = False
        maglight.State = 0
    End If

End Sub


