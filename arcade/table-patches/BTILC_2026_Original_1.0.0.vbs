Dim RampStep, RampDir
RampStep = 0

Const RampClosed = 0
Const RampOpen   = 15

' =========================
' CLOSE RAMP
' =========================
Sub RampDoorClose (EOB)
	if bEOB = False Then bRampOpen(CurrentPlayer) = False
	debug.print "Ramp Door Closed: " & bRampOpen(CurrentPlayer) & " - " & Gametime

    If RampStep = RampOpen Then
        RampDir = -2                  
        RampDoorTimer.Enabled = 1

        RampDoor.Visible = 0
        RampDoor.Collidable = 1

        PlaySound "Saward"
        StopMDoor3
    End If
End Sub
' =========================
' OPEN RAMP
' =========================
Sub RampDoorOpen ( Caller )

	'Debug.print "RampDoor Open?: " & bRampOpen(CurrentPlayer)
	If bRampOpen(CurrentPlayer) AND bForceDoor = False Then Exit Sub



'BeaconEffect_Regular            ' Normal rotating beacon
'BeaconEffect_PulseSpeed         ' Beacon slowly speeds up and slows down NOT USED YET
'BeaconEffect_BlinkSpin_Red      ' Spinning beacon with red blink effect RAIN (NEEDS ADDED)
'BeaconEffect_BlinkSpin_Orange   ' Spinning beacon with orange blink THUNDER  (NEEDS ADDED)
'BeaconEffect_BlinkSpin_SkyBlue  ' Spinning beacon with sky blue blink LIGHTNING (NEEDS ADDED)
'BeaconEffect_BlinkSpin_NeonGreen' Spinning beacon with neon green blink LOPAN
'BeaconEffect_BlinkSpin_Purple   ' Spinning beacon with purple blink NOT USED YET
'BeaconEffect_TripleSpin         ' Random bright color triple spin effect COMBOS
'BeaconEffect_StrobeSpin         ' Fast strobing rotating beacon NOTUSED YET
'BeaconEffect_RainbowSpin        ' Smooth rainbow color cycling beacon ATTRACT
'BeaconEffect_PurpleStrobe       ' Purple strobe flashing beacon MYSTERY
'StopBeacon                      ' Stops the beacon system completely


	Select Case nMiniWizCompleted(CurrentPlayer) 
		Case 0
			BallHandlingQueue.Add "BeaconEffect_BlinkSpin_Red","BeaconEffect_BlinkSpin_Red",24,100,0,0,0,False
		Case 1
			BallHandlingQueue.Add "BeaconEffect_BlinkSpin_Orange","BeaconEffect_BlinkSpin_Orange",24,100,0,0,0,False
		Case 2
			BallHandlingQueue.Add "BeaconEffect_BlinkSpin_SkyBlue","BeaconEffect_BlinkSpin_SkyBlue",24,100,0,0,0,False
