'			PuPlayer.LabelSet pDMD,"Event5D",msg4,1,"{'mt':2,'fonth': "&EOBFontSize&"}"	
		Case 5
			if nModesCompleted(CurrentPlayer) <> 0 then 
				if EOB_Step = 1 Then Playsound "EBAward"
				Msg5 = nModesCompleted(CurrentPlayer) &"  MODES @ " & FormatScore(BONUS_MODESCOMPLETED) &  " = " & FormatScore(int(TmpPoints*EOB_Step))&  " "
