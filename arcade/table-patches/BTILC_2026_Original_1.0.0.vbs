Sub RampDoorTimer_Timer

    RampStep = RampStep + RampDir

    If RampStep <= RampClosed Then
        RampStep = RampClosed
        RampDoorTimer.Enabled = 0
    End If

    If RampStep >= RampOpen Then
        RampStep = RampOpen
        RampDoorTimer.Enabled = 0
    End If
    RampDoor.HeightBottom = RampStep
    SkullRampDown.RotX = RampStep

End Sub

