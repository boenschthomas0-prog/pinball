    Select Case Pan1State

        Case 1
            Pan1Step = Pan1Step + 1
            Select Case Pan1Step
                Case 1
                    pan001.Visible = True
                Case 2
                    pan001.Visible = False
                    pan002.Visible = True
                Case 3
                    pan002.Visible = False
                    pan003.Visible = True
                Case 4
                    pan003.Visible = False
                    pan004.Visible = True
                    Pan1AnimTimer.Enabled = False
            End Select

      Case 2
    Pan1Step = Pan1Step + 1

    If bSuperDelayActive Then
        If Pan1Step >= 14 Then
            Pan1Step = 0
            Pan1State = 3
            bSuperDelayActive = False
