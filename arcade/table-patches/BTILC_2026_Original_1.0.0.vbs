    sorcerer002.Visible = False

    ' Lopan is visible immediately
    lopan001.Visible = True

    sorcerer003.Z = SorcererStartZ
    sorcerer003.Visible = True

    SorcererTimer.Interval = 20
    SorcererTimer.Enabled = True

End Sub


'===========================================
' TEMP SWAP 001 → 002 FOR 2 SECONDS
'===========================================
Sub SwapSorcererTo002()

    If sorcerer001.Visible = False Then Exit Sub

    sorcerer001.Visible = False
    sorcerer002.Visible = True

    SwapBackTimer.Interval = 1500
    SwapBackTimer.Enabled = True

End Sub


Sub SwapBackTimer_Timer()

    SwapBackTimer.Enabled = False
    sorcerer002.Visible = False
    sorcerer001.Visible = True

End Sub


'===========================================
' MODE END HIDE EVERYTHING
'===========================================
Sub EndSorcererMode()

    SorcererTimer.Enabled = False
    SwapBackTimer.Enabled = False
    SorcererRunning = False

    sorcerer001.Visible = False
    sorcerer002.Visible = False
    sorcerer003.Visible = False
    lopan001.Visible    = True
    
     ' RESET LOPAN POSITION
    LoPan_Reset
End Sub


'===========================================
' MAIN TIMER
'===========================================
Sub SorcererTimer_Timer()

    '========================
    ' RISE PHASE (003 ONLY)
    '========================
    If Not SorcererAtTop Then
        sorcerer003.Z = sorcerer003.Z + SorcererZStep

        If sorcerer003.Z >= SorcererEndZ Then
            sorcerer003.Z = SorcererEndZ
            SorcererAtTop = True
        End If

        Exit Sub
    End If

    '========================
    ' FADE PHASE (003 + LOPAN)
    '========================
    SorcererFadeCount = SorcererFadeCount + 1

    ' 003 fades out
    sorcerer003.Visible = (SorcererFadeCount Mod 2 = 0)

    ' Lopan fades opposite
    lopan001.Visible = Not sorcerer003.Visible

    If SorcererFadeCount >= FadePulses Then
        sorcerer003.Visible = False
        lopan001.Visible    = False

        SorcererTimer.Enabled = False
        SorcererRunning = False

        ' Reveal 001
        sorcerer001.Visible = True
    End If

End Sub
