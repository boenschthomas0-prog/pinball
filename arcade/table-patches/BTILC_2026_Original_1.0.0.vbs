    ElseIf bSuperLopan Then
        If Pan1Step >= 12 Then
            Pan1Step = 0
            Pan1State = 3
        End If
    Else
        If Pan1Step >= 2 Then
            Pan1Step = 0
            Pan1State = 3
        End If
    End If

        Case 3 'REVERSE
            Pan1Step = Pan1Step + 1
            Select Case Pan1Step
                Case 1
                    pan005.Visible = False
                    pan003.Visible = True
                Case 2
                    pan003.Visible = False
                    pan002.Visible = True
                Case 3
                    pan002.Visible = False
                    pan001.Visible = True
                Case 4
                    pan001.Visible = False
                    Pan1AnimTimer.Enabled = False
                    Pan1State = 0
