Function FindCurrentMode
	if bBPFlipperActive Then
		FindCurrentMode = "Sewer"

	Elseif bMidnightMadnessMode = True Then 
		FindCurrentMode = "MidnightMadness"

    Elseif bEggShenMagic Then 
        FindCurrentMode = "EggShen"

	Elseif bBPFlipperActive Then
		FindCurrentMode = "Sewer"	

	Elseif nSuperSpinnerMode = 2 Then
		FindCurrentMode = "SuperSpinners"	

	Elseif nWildmanBashMode = 2 Then
		FindCurrentMode = "Wildman"

	Elseif LopanActive = 1 Then
		FindCurrentMode = "MiaoYinMB"	

	Elseif nMiniWizard(Currentplayer,0) <> 0 Then
		Select Case nMiniWizard(Currentplayer,0)
			Case 1
				FindCurrentMode = "Rain"
			Case 2
				FindCurrentMode = "Thunder"
			Case 3
				FindCurrentMode = "Lighting"
			Case 4
				FindCurrentMode = "Lopan"
		End Select

	Elseif Mode(CurrentPlayer,0) <> 0 Then
		Select Case Mode(CurrentPlayer,0)
			Case 1
				FindCurrentMode = "Mode1"	
			Case 2
				FindCurrentMode = "Mode2"	
			Case 3
				FindCurrentMode = "Mode3"	
			Case 4
				FindCurrentMode = "Mode4"	
			Case 5
				FindCurrentMode = "Mode5"	
			Case 6
				FindCurrentMode = "Mode6"	
		End Select

	Elseif bGracieGauntlet Then
		FindCurrentMode = "Gracie"	

	End If

End Function

