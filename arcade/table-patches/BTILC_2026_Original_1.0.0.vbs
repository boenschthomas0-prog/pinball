Sub StartMidnightLights()

	nNM = 3

' Kill EVERYTHING currently running
MadnessActive = True

' 60-second timer
MadnessEndTime = GameTime + 60000   ' 60 seconds

' Stop other systems safely
PulsingTimer.Enabled = False
RapidPulseTimer.Enabled = False
AttractFlasherTimer.Enabled = False
UpDownSweepTimer.Enabled = False
WizardTimer.Enabled = False

Flash4BeaconEnabled = False
Flash4BeaconTimer.Enabled = False

ForceAllFlashersOff

' Start chaos
MidnightMadnessTimer.Interval = 100
MidnightMadnessTimer.Enabled = True

