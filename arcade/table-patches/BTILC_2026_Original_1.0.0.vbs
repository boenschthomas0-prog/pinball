'=====================================
'  OLD LOPAN ADVANCE 
'=====================================

Const LoPan_StartY    = 310.2
Const LoPan_EndY      = 664
Const LoPan_TotalHits = 5

Dim LoPan_StepY


' Steps
LoPan_StepY = (LoPan_EndY - LoPan_StartY) / LoPan_TotalHits

Sub LoPan_Advance()
    If nCaptiveBallHits(CurrentPlayer) > LoPan_TotalHits Then Exit Sub

    ' First advance only → open door
    If nCaptiveBallHits(CurrentPlayer) = 1 Then
        LoPanDoor_OpenTemp
    End If

    lopan001.Y = lopan001.Y + LoPan_StepY

    ' Safe
    If lopan001.Y > LoPan_EndY Then lopan001.Y = LoPan_EndY

 '   Debug.Print "LoPan Advance: " & lopan001.Y
End Sub

Sub LoPan_Update
	lopan001.Y = LoPan_StartY + (nCaptiveBallHits(CurrentPlayer) * LoPan_StepY)
End Sub

Sub LoPan_Reset()
    lopan001.Y = LoPan_StartY
    LoPan_ResetSpinStart

    LoPanDoor_OpenTemp
End Sub

'=====================================
'  LOPAN RESET SPIN
'=====================================

Dim LoPan_ResetTicks
Dim LoPan_ResetBaseRot

Sub LoPan_ResetSpinStart()

    LoPan_ResetTicks = 0
    LoPan_ResetBaseRot = lopan001.RotZ

    LoPanResetSpinTimer.Enabled = True

End Sub

Sub LoPanResetSpinTimer_Timer()

    LoPan_ResetTicks = LoPan_ResetTicks + 1

    ' Smooth spin back to center
    lopan001.RotZ = LoPan_ResetBaseRot - (LoPan_ResetTicks * 45)

    If LoPan_ResetTicks >= 8 Then
        LoPanResetSpinTimer.Enabled = False
        lopan001.RotZ = 0
    End If

End Sub

Dim LoPanDoorActive

Sub LoPanDoor_OpenTemp()
     If LoPanActive = 1 Then Exit Sub

    ' Prevent re-trigger spam
    If LoPanDoorActive Then Exit Sub

    LoPanDoorActive = True

    lopandoor001.Visible = False
    lopandoor002.Visible = True

    LoPanDoorTimer.Interval = 500
    LoPanDoorTimer.Enabled = True
End Sub

Sub LoPanDoorTimer_Timer()
    LoPanDoorTimer.Enabled = False

    lopandoor002.Visible = False
    lopandoor001.Visible = True

    LoPanDoorActive = False
End Sub

'====================
' Shake Cat Statues
'====================

Dim CatLPos, CatRPos

Sub ShakeLeftCat
    CatLPos = 8
    CatLTimer.Enabled = 1
End Sub

Sub CatLTimer_Timer
    CatL.TransY = CatLPos
    If CatLPos = 0 Then Me.Enabled = 0:Exit Sub
    If CatLPos < 0 Then
        CatLPos = ABS(CatLPos)- 1
    Else
        CatLPos = - CatLPos + 1
