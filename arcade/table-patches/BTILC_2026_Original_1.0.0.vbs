'			PuPlayer.LabelSet pDMD,"Event5A",msg1,1,"{'mt':2,'fonth': "&EOBFontSize&"}"	 
		Case 2
			if orbitcount <> 0 then 
			'debug.print "orbit:" & FormatScore(int(TmpPoints*EOB_Step))
				if EOB_Step = 1 Then Playsound "EBAward"
				Msg2 = OrbitCount &"  ORBITS @ " & FormatScore(BONUS_ORBITS) &  " = " & FormatScore(int(TmpPoints*EOB_Step))&  " "
				if bStandAlone Then 
