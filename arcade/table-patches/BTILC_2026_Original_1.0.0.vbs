Dim LPShakePos           

Sub InitLoPanShake()
    LPShakePos = 0
    LoPanShakeTimer.Interval = 10
    LoPanShakeTimer.Enabled = False
End Sub
'-----------------------------
' START SHAKE
'-----------------------------
Sub StartLoPanShake()
    LPShakePos = 18      ' strength of shake
    LoPanShakeTimer.Enabled = True
End Sub
'-----------------------------
' SHAKE TIMER
'-----------------------------
Sub LoPanShakeTimer_Timer()

    ' Apply the shake to both primitives
    LoPan001.TransY = LPShakePos
    Sorcerer002.TransY = LPShakePos
    Sorcerer001.TransY = LPShakePos
    If LPShakePos = 0 Then
        LoPanShakeTimer.Enabled = False
        Exit Sub
    End If
    If LPShakePos < 0 Then
        LPShakePos = Abs(LPShakePos) - 2
    Else
        LPShakePos = -LPShakePos + 2
    End If

End Sub

