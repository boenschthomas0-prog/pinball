				End If
			Else
				if EOB_Step = 1 Then Playsound "zerotally"
			End If
'			Msg2 = OrbitCount &"  ORBITS @ " & FormatScore(BONUS_ORBITS) &  " = " & FormatScore(int(TmpPoints*EOB_Step))
'			PuPlayer.LabelSet pDMD,"Event5B",msg2,1,"{'mt':2,'fonth': "&EOBFontSize&"}"	
		Case 3
			if nComboCountRoundHigh <> 0 then 
				if EOB_Step = 1 Then Playsound "EBAward"
				Msg3 = nComboCountRoundHigh &" COMBOS @ " & FormatScore(BONUS_COMBO) &  " = " & FormatScore(int(TmpPoints*EOB_Step))&  " "
