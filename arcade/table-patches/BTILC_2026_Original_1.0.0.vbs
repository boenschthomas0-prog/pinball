'NOTE: The TiltDecreaseTimer Subtracts .01 from the "Tilt" variable every round

Sub CheckTilt                                    'Called when table is nudged
	if bEOB Then Exit Sub
    Tilt = Tilt + TiltSensitivity                'Add to tilt count
    TiltDecreaseTimer.Enabled = True
    If(Tilt> TiltSensitivity) AND(Tilt <15) Then 'show a warning
    End if
    If Tilt> 15 Then 'If more that 15 then TILT the table
        Tilted = True
        'display Tilt
		
		if bBallInPlungerLane Then PlungerIM.Autofire:DOF 123, DOFPulse

		ClearSplash
		PuPlayer.playevent pDMD,"Misc","Tilted.mp4",nPupVideoVolume,89,0,3,""
	debug.print "PEA: " & pDMD_Effect_Active

		if PupDMD_Effects_Enabled AND pDMD_Effect_Active = False Then PuPlayer.SendMsg "{ ""mt"":301, ""SN"":5, ""FN"":60, ""EF"":7, ""IN"":0.2, ""ED"":7}"
		GeneralPupQueue.Add "pDMD_Effect_Stop", "pDMD_Effect_Stop", 50, 7100, 0,0,0,False 
        DisableTable True
        TiltRecoveryTimer.Enabled = True 'start the Tilt delay to check for all the balls to be drained
	Elseif Tilt > 6 Then
		if PupDMD_Effects_Enabled AND pDMD_Effect_Active = False Then PuPlayer.SendMsg "{ ""mt"":301, ""SN"":5, ""FN"":60, ""EF"":7, ""IN"":1, ""ED"":2}"
		GeneralPupQueue.Add "pDMD_Effect_Stop", "pDMD_Effect_Stop", 50, 2100, 0,0,0,False 
		GeneralPupQueue.Add "PlayTiltMsg", "PlayTiltMsg", 50, 700, 0,0,0,False
    End If
End Sub

Sub TiltDecreaseTimer_Timer
    ' DecreaseTilt
    If Tilt> 0 Then
        Tilt = Tilt - 0.1
    Else
        TiltDecreaseTimer.Enabled = False
    End If
End Sub

