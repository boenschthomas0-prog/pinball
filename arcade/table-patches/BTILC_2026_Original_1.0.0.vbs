Sub CheckForSuperJackpot
	if JL(0) + JL(1) + JL(2) + JL(3) + JL(4) + JL(5) + JL(6) + JL(7) = 0 Then
		bSuperJackpotActive = True
		nNewSuperJPShot = 0
		ChaseLight
		ChaseTimerReset
	End If
End Sub


Sub ChaseTimerReset
	SuperJackpotChase.Enabled = False
	SuperJackpotChase.Enabled = True
End Sub

Sub SuperJackpotChase_Timer()
	nNewSuperJPShot = nNewSuperJPShot + 1
	Debug.print "Light:" & nNewSuperJPShot
	if nNewSuperJPShot > 7 Then nNewSuperJPShot = 0
	ChaseLight
	ChaseTimerReset
End Sub


