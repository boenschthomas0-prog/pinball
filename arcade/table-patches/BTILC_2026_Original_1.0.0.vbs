Dim AttractTimerCount
Sub AttractTimer_Timer()
	Select Case AttractTimerCount
		Case 0
			AutoQA = True
			debug.print "AUTO QA TIMER -- ON : " & Gametime
			AutoQAStartGame.Enabled = True
			'debug.print "Starting Attract Case 0"
			AttractTimer.Interval = 2500
			if NOT bSupressAttractMsg Then
				PuPlayer.LabelSet pDMD,"Attract1"," GRAND CHAMPION ",1,"{'mt':2,'color': " & cGreen &" }"
				pDMDLabelSetColorGradient "Attract1", cGreen, cBoltYellow
				'pDMDLabelSetBorder "Attract1",cWhite,6,6,1
				PuPlayer.LabelSet pDMD,"Attract2a"," "& HighScoreName(0) &" ",1,"{'mt':2,'color': " & cPurple &" }"
				PuPlayer.LabelSet pDMD,"Attract2b"," "& FormatScore(HighScore(0)) &" ",1,"{'mt':2,'color': " & cRed &" }" 

			End If
		Case 1
			if NOT bSupressAttractMsg Then
				PuPlayer.LabelSet pDMD,"Attract1"," HIGH SCORE 1 ",1,"{'mt':2,'color': " & cBlue &" }"
				pDMDLabelSetColorGradient "Attract1", cBlue, cBoltYellow
				'pDMDLabelSetBorder "Attract1",cWhite,6,6,1
				PuPlayer.LabelSet pDMD,"Attract2a"," "& HighScoreName(1)&" ",1,""
				PuPlayer.LabelSet pDMD,"Attract2b"," "& FormatScore(HighScore(1)) &" ",1,""   
			End If
		Case 2
			if NOT bSupressAttractMsg Then
				PuPlayer.LabelSet pDMD,"Attract1"," HIGH SCORE 2 ",1,"{'mt':2,'color': " & cPurple &" }"
				pDMDLabelSetColorGradient "Attract1", cPurple, cBoltYellow
				'pDMDLabelSetBorder "Attract1",cBlack,6,6,1
				PuPlayer.LabelSet pDMD,"Attract2a"," "& HighScoreName(2)&" ",1,""
				PuPlayer.LabelSet pDMD,"Attract2b"," "& FormatScore(HighScore(2)) &" ",1,""   
			End If
		Case 3
			if NOT bSupressAttractMsg Then
				PuPlayer.LabelSet pDMD,"Attract1"," HIGH SCORE 3 ",1,"{'mt':2,'color': " & cRed &" }"
				pDMDLabelSetColorGradient "Attract1", cRed, cBoltYellow
				PuPlayer.LabelSet pDMD,"Attract2a"," "& HighScoreName(3)&" ",1,""
				PuPlayer.LabelSet pDMD,"Attract2b"," "& FormatScore(HighScore(3)) &" ",1,""   
			End If
		Case 4
			if NOT bSupressAttractMsg Then
				'PuPlayer.LabelSet pDMD,"Attract1"," BRUCE LEE ",1,"{'mt':2,'color': " & cPurple &" }"
				PuPlayer.LabelSet pDMD,"Attract1","",0,""
				PuPlayer.LabelSet pDMD,"Attract2a","Highest Combo",1,"{'mt':2,'color': " & cSilver &" }" 
				PuPlayer.LabelSet pDMD,"Attract2b", " "& HighestComboName &" " & HighestCombo &" ",1,""
				pDMDLabelSetColorGradient "Attract2a", cPurple, cBoltYellow
				pDMDLabelSetColorGradient "Attract2b", cWhite, cSilver
			End If
		Case 5
			AttractTimer.Interval = 38501
			ClearPupAttractMessages
		Case 6
			BallhandlingQueue.Add "AutoQA = True","AutoQA = True: debug.print ""back on"" ",95,150,0,0,0,False
			StopAttractMode
			
		Case Else		
			' Do nothing
	End Select

	AttractTimerCount = AttractTimerCount + 1
	if AttractTimerCount > 6 Then AttractTimerCount = 0
End Sub

