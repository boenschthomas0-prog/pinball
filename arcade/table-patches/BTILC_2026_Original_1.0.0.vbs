Function CheckAdvanceModes
debug.print "Check Advance Modes Called "
	Select Case nModesCompleted(CurrentPlayer)
		Case 0 
			CheckAdvanceModes = True
		Case 1
			if nSewerReturn(CurrentPlayer) < 1 Then 
				CheckAdvanceModes = False	
			Else
				CheckAdvanceModes = True	
			End If
		Case 2
			if nMiniWizCompleted(CurrentPlayer) = 1 Then 
				CheckAdvanceModes = True
			Else
				CheckAdvanceModes = False
			End If
		Case 3
			if nSewerReturn(CurrentPlayer) < 2 Then 
				CheckAdvanceModes = False	
			Else
				CheckAdvanceModes = True	
			End If
		Case 4
			if nMiniWizCompleted(CurrentPlayer) = 2 Then 
				CheckAdvanceModes = True
			Else
				CheckAdvanceModes = False
			End If
		Case 5
			if nSewerReturn(CurrentPlayer) < 3 Then 
				CheckAdvanceModes = False	
			Else
				CheckAdvanceModes = True	
			End If
		Case 6
			if nMiniWizCompleted(CurrentPlayer) = 3 Then 
				'CheckAdvanceModes = True
				' Do we prep for lopan mode here ?
				rampdooropen "function-CheckAdvanceModes"
			Else
				CheckAdvanceModes = False
			End If
	End Select
End Function

