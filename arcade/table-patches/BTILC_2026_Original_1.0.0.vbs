Sub CheckCombo
	'debug.print "LSH:" &LastSwitchHit

	nComboCount = nComboCount + 1


	if nComboCount > 3 Then
		if ballsonplayfield <= 2 AND LastSwitchHit <> "LeftRamp" Then PlaySound "Combo_" & nComboCount
        BeaconEffect_TripleSpin
	End If


	ResetComboTimer
	DisplayDMDComboValue
	ResetComboTimer



End Sub

sub ResetComboTimer
	ComboTimer.Enabled = False	
	ComboTimer.Enabled = True
End Sub

Sub ComboTimer_Timer
	EndCombo
End Sub


Sub DestroyCombo
	if nComboCount > 0 Then AddScore (nComboScoreInitial*nComboCount), "Center"
	ComboTimer.Enabled = 0
	'tmrBonusCountup.Enabled = False
	ClearComboLines
	ClearComboCounts
End Sub


'Dim bSupressComboMsg
Sub EndCombo

'debug.print "ENDING COMBO:" &nComboCount

	ComboTimer.Enabled = False

	if ComboHigh(CurrentPlayer) < nComboCount Then 
		ComboHigh(CurrentPlayer) = nComboCount
		If HighestCombo < nComboCount Then 
			if bEBCombo(CurrentPlayer) Then 
				bExtraballReady(CurrentPlayer) = 2
				PlaySound "vo_ExtraBallIsLit", 0 , fCalloutVolume
				DOF 164, DOFPulse
				Debug.print " Extraball is lit - highest combo"
			End If
			bEBCombo(CurrentPlayer) = False
		End If
	End If
	
	if nComboCountRoundHigh < nComboCount Then 
		nComboCountRoundHigh = nComboCount
	End If


'	debug.print "Combo High: " & nComboCountRoundHigh


	ClearComboCounts

End Sub


