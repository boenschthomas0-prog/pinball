'========================================================
'   UP/DOWN TABLE SWEEP (1&2 then 3&4) x2
'========================================================

Dim SweepStep
Dim SweepCount
Dim SweepMaxSteps
Dim FlasherSweepActive
Sub StartUpDownSweep()

    ' 4 steps per cycle (Top, Bottom, Top, Bottom)
    ' 2 cycles = 8 steps total
    SweepStep = 0
    SweepCount = 0
    SweepMaxSteps = 8

    UpDownSweepTimer.Interval = 160   ' speed (lower = faster)
    UpDownSweepTimer.Enabled = True

End Sub


Sub UpDownSweepTimer_Timer()

    FlasherSweepActive = True

    ' STEP 1 — FULL HARD KILL (including internal flupper timers)
    Dim i
    For i = 1 To 4
        ObjTargetLevel(i) = 0
        objflasher(i).TimerEnabled = False
        objflasher(i).visible = 0
        objbloom(i).visible = 0
        objlit(i).visible = 0
        objlight(i).IntensityScale = 0
        ObjLevel(i) = 0
    Next

    ' STEP 2 — Fire ONLY the intended pair
    Select Case SweepStep

        Case 0, 2
            ' TOP ONLY (1 & 2)
            ObjTargetLevel(1) = 1
            ObjTargetLevel(2) = 1
            FlasherFlash1_Timer
            FlasherFlash2_Timer

        Case 1, 3
            ' BOTTOM ONLY (3 & 4)
            ObjTargetLevel(3) = 1
            ObjTargetLevel(4) = 1
            FlasherFlash3_Timer
            FlasherFlash4_Timer

    End Select

    SweepStep = SweepStep + 1
    SweepCount = SweepCount + 1

    If SweepStep > 3 Then SweepStep = 0

    ' End after 2 full sweeps
If SweepCount >= SweepMaxSteps Then

    UpDownSweepTimer.Enabled = False
    FlasherSweepActive = False

    ' FULL HARD RESET first (prevents stuck glow)
    Dim j
    For j = 1 To 4
        ObjTargetLevel(j) = 0
        ObjLevel(j) = 0
        objflasher(j).TimerEnabled = False
        objbloom(j).visible = 0
        objlit(j).visible = 0
        objlight(j).IntensityScale = 0
    Next

    ' Force render OFF state cleanly
    FlasherFlash1_Timer
    FlasherFlash2_Timer
    FlasherFlash3_Timer
    FlasherFlash4_Timer

    ' NOW set final visual state:
    ' Base 1 & 2 visible (plastic dome look)
    objflasher(1).visible = 1
    objflasher(2).visible = 1

    ' Make sure lit layers stay OFF
    objlit(1).visible = 0
    objlit(2).visible = 0
    objbloom(1).visible = 0
    objbloom(2).visible = 0
    objlight(1).IntensityScale = 0
    objlight(2).IntensityScale = 0

End If
End Sub

