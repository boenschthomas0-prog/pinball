' Eject the ball after the delay, AddMultiballDelay
Sub CreateMultiballTimer_Timer()
    ' wait if there is a ball in the plunger lane
    If bBallInPlungerLane Then
		Debug.print "WAIT YOUR TURN - " & Gametime
        Exit Sub
    Else
        If BallsOnPlayfield < MaxMultiballs Then
			if BallsInHole > 0 Then 
				BallsInHole = BallsInHole - 1
				debug.print "Create New Ball BIH - : " & ballsinhole   & ":" & ballsonplayfield 
			End If
            CreateNewBall()
            mBalls2Eject = mBalls2Eject - 1
			Debug.print "Balls LEFT to EJECT: " &  mBalls2Eject

            If mBalls2Eject = 0 Then 'if there are no more balls to eject then stop the timer
                CreateMultiballTimer.Enabled = False
            End If
        Else 'the max number of multiballs is reached, so stop the timer
			'MsgBox "Max Balls : " & BallsOnPlayfield
			Debug.print "Max Balls Reached - Balls Left = " &  mBalls2Eject

            mBalls2Eject = 0
		
            CreateMultiballTimer.Enabled = False
        End If
    End If
End Sub


