'==================================================================================================================================
' Called when options are tweaked by the player. 
' - 0: game has started, good time to load options and adjust accordingly
' - 1: an option has changed
' - 2: options have been reseted
' - 3: player closed the tweak UI, good time to update staticly prerendered parts

' Table1.Option arguments are: 
' - option name, minimum value, maximum value, step between valid values, default value, unit (0=None, 1=Percent), an optional arry of literal strings

Dim dspTriggered : dspTriggered = False
Sub Table1_OptionEvent(ByVal eventId)
Dim instrV

	If eventId = 1 And Not dspTriggered Then dspTriggered = True : DisableStaticPreRendering = True : End If

	'-----Instruction Mode-----
	instrV = Table1.Option("Instruction Mode", 0, 1, 1, 0, 0, Array("Off", "On"))

	'-----Midnight MAdness Mode-----
	bMM = Table1.Option("Midnight Madness Mode", 0, 1, 1, 1, 0, Array("Off", "(Default) On"))

	'-----Pinup v2.0 Enable-----
	PupDMD_Effects_Enabled = Table1.Option("Pinup V2 Enabled", 0, 1, 1, 0, 0, Array("(Default) Off", "On"))		


	If instrV = 1 Then
		If Not gInstructionMode Then BeginInstructionMode
	Else
		If gInstructionMode Then EndInstructionMode
	End If

    ' VRRoom
	VRRoomChoice = Table1.Option("VR Room", 0, 2, 1, 2, 0, Array("OFF","Cab", "Mega"))
	LoadVRRoom
    
    ' Sound volumes
    VolumeDial = Table1.Option("Mech Volume", 0, 1, 0.01, 0.8, 1)
    BallRollVolume = Table1.Option("Ball Roll Volume", 0, 1, 0.01, 0.5, 1)
	RampRollVolume = Table1.Option("Ramp Roll Volume", 0, 1, 0.01, 0.5, 1)
	fMusicVolume = Table1.Option("Music Volume - Default 65%", 0, 1, 0.001, 0.65, 1)

	fCalloutVolume = Table1.Option("Callout Volume", 0, 1.5, 0.01, .9, 1)


	' Reset HS
	bResetHS = Table1.Option("Reset High Scores", 0, 1, 1, 0, 0, Array("Off (Default)", "On"))
	

	'MiniGame
	bMiniGame = Table1.Option("Mini Game", 0, 1, 1, 1, 0, Array("Off", "On (Default) "))

	'Freeplay
	bFreeplay = Table1.Option("Freeplay On", 0, 1, 1, 0, 0, Array("Off (Default)", "True"))

	' Super Spinner Animation
	bSpinnerAnim = Table1.Option("Super Spinner Animation", 0, 1, 1, 1, 0, Array("Off", "On (Default)"))

	'GPU/CPU Processing Power
	' 0 Slow: Anything below Nvidia 3060/i7
	' 1 Normal: 3060 - 4070 / i9 
	' 2 Fast: 4080 + 
	nPCMod = Table1.Option("Graphics Setting", 0, 2, 1, 1, 0, Array("Low", "Medium", "High"))

	'Randomize Modes
	bRandomModes = Table1.Option("Randomize Modes", 0, 1, 1, 1, 0, Array("Off", "(Default) On"))  

	
'	'Lockdown bar Visible
