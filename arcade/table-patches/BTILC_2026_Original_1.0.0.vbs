    ArrowStep = (ArrowStep + 1) Mod 360

    If secretpassagearrow001.Visible Then secretpassagearrow001.height = secretpassagearrow001.height + Sin(ArrowStep * ArrowPi) * 0.5
    If secretpassagearrow002.Visible Then secretpassagearrow002.X = secretpassagearrow002.X + Sin(ArrowStep * ArrowPi) * 0.3
    If secretpassagearrow002.Visible Then secretpassagearrow002.Y = secretpassagearrow002.Y + Sin(ArrowStep * ArrowPi) * 0.3
    If Questarrow001.Visible Then QuestArrow001.Y = QuestArrow001.Y + Sin(ArrowStep * ArrowPi) * 0.3
    If Questarrow002.Visible Then QuestArrow002.X = QuestArrow002.X + Sin(ArrowStep * ArrowPi) * 0.3
    If EddieArrow001.Visible Then EddieArrow001.Y = EddieArrow001.Y + Sin(ArrowStep * ArrowPi) * 0.3
    If BonusMPArrow001.Visible Then Bonusmparrow001.Y = BonusMPArrow001.Y + Sin(ArrowStep * ArrowPi) * 0.3
    If BonusMPArrow001.Visible Then Bonusmparrow001.X = BonusMPArrow001.X + Sin(ArrowStep * ArrowPi) * 0.3
    If PlayfieldMArrow001.Visible Then PlayfieldMArrow001.X = PlayfieldMArrow001.X + Sin(ArrowStep * ArrowPi) * 0.3
    If PlayfieldMArrow001.Visible Then PlayfieldMArrow001.Y = PlayfieldMArrow001.Y + Sin(ArrowStep * ArrowPi) * 0.3
    If WangArrow001.Visible Then WangArrow001.X = WangArrow001.X + Sin(ArrowStep * ArrowPi) * 0.3
    If WangArrow002.Visible Then WangArrow002.X = WangArrow002.X + Sin(ArrowStep * ArrowPi) * -0.3
    If WildmanArrow001.Visible Then WildmanArrow001.Y = WildmanArrow001.Y + Sin(ArrowStep * ArrowPi) * 0.3
    If SewerArrow001.Visible Then SewerArrow001.X = SewerArrow001.X + Sin(ArrowStep * ArrowPi) * 0.3
    If SewerArrow001.Visible Then SewerArrow001.Y = SewerArrow001.Y + Sin(ArrowStep * ArrowPi) * 0.3
    If WizArrow001.Visible Then WizArrow001.Y = WizArrow001.Y + Sin(ArrowStep * ArrowPi) * 0.3
    If WildmanArrow002.Visible Then WildmanArrow002.height = WildmanArrow002.height + Sin(ArrowStep * ArrowPi) * 0.5
    If SuperSpinArrow001.Visible Then SuperSpinArrow001.height = SuperSpinArrow001.height + Sin(ArrowStep * ArrowPi) * 0.5
    If SuperSpinArrow002.Visible Then SuperSpinArrow002.height = SuperSpinArrow002.height + Sin(ArrowStep * ArrowPi) * 0.5
