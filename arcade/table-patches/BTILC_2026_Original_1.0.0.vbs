Sub StartIron()
    Playsound "Zap"
   
    IronFlash.Visible = True
    Iron2Flash.Visible = True

    Iron1Pos = 0
    Iron2Pos = 2

    IronTimeLeft = IronRunTime
    IronTimer.Enabled = True
