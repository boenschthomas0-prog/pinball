' If a whole bank of drop targets can be reset at once, use sub like below

Sub SolDTBank(enabled)
'	Dim xx
	If enabled Then
		RandomSoundDropTargetReset sw2p
		DTRaise 1
		DTRaise 2
		DTRaise 3
		DTRaise 4

		DroppedTargets(1) = 1
		DroppedTargets(2) = 1
		DroppedTargets(3) = 1
		DroppedTargets(4) = 1

'		For Each xx In ShadowDT
'			xx.visible = True
'		Next
	End If
End Sub

