		Debug.Print "RAMPS: " & RampCount &" * " & BONUS_RAMPS &" = "&(RampCount*BONUS_RAMPS)* nBonusMultiplier(CurrentPlayer)
		Debug.Print "ORBITS: " & OrbitCount &" * " &BONUS_ORBITS &" = "&(OrbitCount*BONUS_ORBITS)* nBonusMultiplier(CurrentPlayer)
		Debug.Print "COMBO: " & nComboCountRoundHigh &" * " & BONUS_COMBO &" = "&(nComboCountRoundHigh*BONUS_COMBO)* nBonusMultiplier(CurrentPlayer)
		Debug.Print "SPINNERS: " & SpinnerCount &" * " & BONUS_SPINNER &" = "&(SpinnerCount*BONUS_SPINNER)* nBonusMultiplier(CurrentPlayer)
		Debug.Print "MODES: " & nModesCompleted(CurrentPlayer) &" * " & BONUS_MODESCOMPLETED &" = "&(nModesCompleted(CurrentPlayer)*BONUS_MODESCOMPLETED)* nBonusMultiplier(CurrentPlayer)
		Debug.Print "BONUS: " & BonusPoints(CurrentPlayer)

'&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&
'               ############################    END OF SCORING    #########################################################
'&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&&


'BallHandlingQueue.Add "ChangeGI White", "ChangeGI White:ClearGlowBalls", 50, 750, 0,0,0,False
'debug.print "EOB2 - " &gametime

	'PlayModeMusic	
    Tilted = False
    Tilt = 0
    DisableTable False 'enable again bumpers and slingshots

	if bMidnightMadnessMode Then EndOfBallComplete()

	if bSuperMysteryReward(CurrentPlayer) OR bMysteryReward(CurrentPlayer) Then 
		MysteryControllerClose
	End If

    ' has the player won an extra-ball ? (might be multiple outstanding)
    If(ExtraBallsAwards(CurrentPlayer) <> 0) Then
        'debug.print "Extra Ball"

        ' yep got to give it to them
        ExtraBallsAwards(CurrentPlayer) = ExtraBallsAwards(CurrentPlayer) - 1
		UpdateExtraBalls
		pDMDSplashOneLine " SHOOT AGAIN ",3000,cRed

        ' if no more EB's then turn off any shoot again light
        If(ExtraBallsAwards(CurrentPlayer) = 0) Then
			DOF 175, DOFOff
			'pDMDSplashOneLine " SHOOT AGAIN ",3000,cRed
            'LightShootAgain.State = 0
        End If

        ' reset the playfield for the new ball
		'debug.print "Calling RFNB - EOB2: " & GameTime
        ResetForNewPlayerBall()
		
		' set the dropped wall for bonus

		
        ' Create a new ball in the shooters lane
        CreateNewBall()
    Else ' no extra balls

        BallsRemaining(CurrentPlayer) = BallsRemaining(CurrentPlayer) - 1

		GeneralPupQueue.Add "PlayerUpVideo","PlayerUpVideo",65,700,0,0,0,False

        ' was that the last ball ?
        If(BallsRemaining(CurrentPlayer) <= 0) Then
            'debug.print "No More Balls, High Score Entry"

            ' Submit the CurrentPlayers score to the High Score system
            if AutoQA = False Then CheckHighScore()	: debug.print "damnit"

			if AutoQA = True Then EndOfBallComplete()
        ' you may wish to play some music at this point

        Else

            ' not the last ball (for that player)
            ' if multiple players are playing then move onto the next one
            EndOfBallComplete()
        End If
    End If
End Sub

' This function is called when the end of bonus display
' (or high score entry finished) AND it either end the game or
' move onto the next player (or the next ball of the same player)
'
Sub EndOfBallComplete()
    Dim NextPlayer

	DisableMagnet

	'pDMD_Effect_Active = False
	pdmd_effect_stop

'	ClearInitials
'	ClearBanners

	ClearEOBDMD
	bInEOB = False

	Debug.print "EOBC: " & bMidnightMadnessMode
	if bMidnightMadnessMode Then StartMidnightMadness2 : Exit Sub


	debug.print "PASSED SMM2"

	if AutoQA Then bJackBusy = False
    
   ' debug.print "EndOfBall - Complete - " & gametime

    ' are there multiple players playing this game ?
    If(PlayersPlayingGame> 1) Then
        ' then move to the next player
        NextPlayer = CurrentPlayer + 1
        ' are we going from the last player back to the first
        ' (ie say from player 4 back to player 1)
        If(NextPlayer> PlayersPlayingGame) Then
            NextPlayer = 1
        End If
    Else
        NextPlayer = CurrentPlayer
    End If

    'debug.print "Next Player = " & NextPlayer

    ' is it the end of the game ? (all balls been lost for all players)
    If((BallsRemaining(CurrentPlayer) <= 0) AND(BallsRemaining(NextPlayer) <= 0) ) Then
        ' you may wish to do some sort of Point Match free game award here
        ' generally only done when not in free play mode

		PlaySound ""
        ' set the machine into game over mode
        vpmtimer.addtimer 1000, "EndOfGame() '"

    ' you may wish to put a Game Over message on the desktop/backglass

    Else
        ' set the next player
        CurrentPlayer = NextPlayer

        ' reset the playfield for the new player (or new ball)
	'	debug.print "Calling RFNB - EOBC: " & GameTime
        ResetForNewPlayerBall()

        ' AND create a new ball
	'	Debug.print "Loading Next Ball"
        CreateNewBall()

        ' play a sound if more than 1 player
        If PlayersPlayingGame> 1 Then
            PlaySound "vo_player" &CurrentPlayer, 0 , fCalloutVolume
        End If
    End If
End Sub

' This function is called at the End of the Game, it should reset all
' Drop targets, AND eject any 'held' balls, start any attract sequences etc..

Sub EndOfGame()
	
	JackCallout.Enabled = False
	'AutoQA_Expedite = False
    LightSeqAttract.StopPlay
	'debug.print "End Of Game"
    bGameInPlay = False
    ' just ended your game then play the end of game tune
    If NOT bJustStarted Then
		StopAllMusic
'		SwitchMusic "mu_GameOver"
    End If

	ClearInitials
	ClearBanners

    bJustStarted = False
    ' ensure that the flippers are down
    SolLFlipper 0
    SolRFlipper 0

    ' terminate all Mode - eject locked balls
    ' most of the Mode/timers terminate at the end of the ball

    ' set any lights for the attract mode
    GiOff

'	EndOfGameScoreServer

	GeneralPupQueue.Add "PlayGameOverVideo","PlayGameOverVideo",25,200,0,0,0,False
	GeneralPupQueue.Add "StartAttractMode","StartAttractMode",25,25000,0,0,0,False
    
' you may wish to light any Game Over Light you may have
End Sub

Function Balls
    Dim tmp
    tmp = BallsPerGame - BallsRemaining(CurrentPlayer) + 1
    If tmp> BallsPerGame Then
        Balls = BallsPerGame
    Else
        Balls = tmp
    End If
End Function

