Sub Table1_KeyDown(ByVal Keycode)

	if keycode = "11" And bResetHS Then ResetHS:SaveHS




    If Keycode = AddCreditKey AND bGameInPlay = False Then
        if bFreePlay = False Then Credits = Credits + 1:DOF 140, DOFPulse
		if bDelayIntro Then PlaySound "VO_AddCredits3"

		bSupressAttractMsg = True
		ClearPupAttractMessages
		DMDQueue.Add "bSupressAttractMsg = False-"&Gametime,"bSupressAttractMsg = False",95,2100,0,0,0,True

		SupressModeMessages 2100

		if bGameInPlay = False Then 
			pDMDSplashOneLine Credits & " CREDITS ",2000,cRed
			DMDQueue.Add "ClearSplash","ClearSplash",95,2100,0,0,0,True
		End If
        if bFreePlay = 0 Then
            DOF 125, DOFOn
			DOF 140, DOFPulse
            If(Tilted = False) Then
				Select Case Int(rnd*3)
					Case 0: PlaySound ("Coin_In_1"), 0, CoinSoundLevel, 0, 0.25
					Case 1: PlaySound ("Coin_In_2"), 0, CoinSoundLevel, 0, 0.25
					Case 2: PlaySound ("Coin_In_3"), 0, CoinSoundLevel, 0, 0.25
				End Select
            End If
        End If
    End If

    If keycode = PlungerKey AND hsbmodeactive = False Then

		
		If BallsOnPlayfield = 1 AND bBallInPlungerLane = False Then StuckBallTimer.Enabled = True

		If VRRoom <> 0 Then
			TimerVRPlunger.Enabled = True
			TimerVRPlunger2.Enabled = False

		End If

		If PuPGameRunning Then 
			PuPGameInfo= PuPlayer.GameUpdate(PuPMiniGameTitle, 1 , 32 , "")  'space		
		Else
			Plunger.Pullback
			if bBallInPlungerLane Then PlaySoundAt "fx_plungerpull", plunger
			if bBallInPlungerLane Then PlaySoundAt "TruckPullback", plunger
		End If

    End If

    If hsbModeActive Then
        EnterHighScoreKey(keycode)
        Exit Sub
    End If

	If keycode = LeftFlipperKey Then
		bLFHeld = True
		If gInstructionMode = True Then
			Instr_PrevFeature
		End If
	End If

    If keycode = RightFlipperKey Then 
		bRFHeld = True
		If gInstructionMode = True Then
			Instr_NextFeature
		End If
	End If

	If gInstructionMode = True And bLFHeld And bRFHeld Then
        EndInstructionMode
        Exit Sub    ' consume input so nothing else fires this frame
    End If

	If AutoQa = True And bLFHeld And bRFHeld Then
		bDoubleCheck = True
		BallHandlingQueue.Add "QuitAutoGame","QuitAutoGame",24,1000,0,0,0,False 
	End If


    ' Normal flipper action

    If bGameInPlay AND NOT Tilted Then


        If keycode = LeftTiltKey Then Nudge 90, 5:SoundNudgeLeft():CheckTilt
        If keycode = RightTiltKey Then Nudge 270, 5:SoundNudgeRight():CheckTilt
        If keycode = CenterTiltKey Then Nudge 0, 3:SoundNudgeCenter():CheckTilt
        If keycode = LeftFlipperKey Then 
			If VRRoom <> 0 Then PinCab_Leftbutton.X = PinCab_Leftbutton.X + 10

			If PuPGameRunning Then 'AOR
				PuPGameInfo= PuPlayer.GameUpdate(PuPMiniGameTitle, 1 , 87 , "")  'w
			Else
				if bEOB AND bRFHeld AND Balls < 3 AND ExtraBallsAwards(CurrentPlayer) = 0 Then ExpediteEOB : debug.print "Expedite called by Left"

				if bLeftFlipperDead Then 
					Playsound "zap"
				Else
					SolLFlipper 1
				End If
			End If
		End If

        If keycode = RightFlipperKey Then 
			If VRRoom <> 0 Then PinCab_Rightbutton.X = PinCab_Rightbutton.X - 10

			If PuPGameRunning Then 'AOR
				PuPGameInfo= PuPlayer.GameUpdate(PuPMiniGameTitle, 1 , 83 , "")  's
			Else
				bRFHeld = True
				if bEOB AND bLFHeld AND Balls < 3 AND ExtraBallsAwards(CurrentPlayer) = 0 Then ExpediteEOB : debug.print "Expedite called by Right"

				if bRightFlipperDead Then 
					Playsound "zap"				
				Else
					SolRFlipper 1
				End If
			End If
		End If

		If keycode = RightFlipperKey AND bSkillTargetSelect AND gInstructionMode = False Then ReverseDT:Playsound "vo_SkillSelect"
		If keycode = LeftFlipperKey AND bSkillTargetSelect AND gInstructionMode = False Then AdvanceDT:Playsound "vo_SkillSelect"
        
        If keycode = StartGameKey AND bGameReady Then
			soundStartButton()
            If((PlayersPlayingGame <MaxPlayers) AND(bOnTheFirstBall = True) ) Then

                If(bFreePlay = 1) Then
                    PlayersPlayingGame = PlayersPlayingGame + 1
					if bAttractMode Then StopAttractMode
					PlayersInGameAudio
                    TotalGamesPlayed = TotalGamesPlayed + 1
                Else
                    If(Credits> 0) then
                        PlayersPlayingGame = PlayersPlayingGame + 1
						if bAttractMode Then StopAttractMode
						PlayersInGameAudio
                        TotalGamesPlayed = TotalGamesPlayed + 1
                        Credits = Credits - 1
						if bGameInPlay = False Then pDMDSplashOneLine Credits & " CREDITS ",3000, cRed
                        If Credits <1 And bFreePlay = 0 Then DOF 125, DOFOff
                        Else
							'pDMDSplashTwoLines " INSERT COIN ","NO CREDITS",3, cRed
							bDelayIntro = True
							if bAttractMode Then StopAttractMode
							PlaySound "VO_AddCredits2"
							ClearPupAttractMessages
							bSupressAttractMsg = True
							DMDQueue.Add "bSupressAttractMsg = False-"&Gametime,"bSupressAttractMsg = False",95,3100,0,0,0,True
							if bGameInPlay = False Then pDMDSplashOneLine " INSERT COIN ",3000,cRed
                            ' Not Enough Credits to start a game.
                    End If
                End If
            End If
        End If
        Else ' If (GameInPlay)

            If keycode = StartGameKey AND bGameReady Then
				soundStartButton()
                If(bFreePlay = 1) Then
                    If(BallsOnPlayfield = 0) Then
                        ResetForNewGame()
						'PlayModeMusic
                    End If
                Else
                    If(Credits> 0) Then
                        If(BallsOnPlayfield = 0) Then
                            Credits = Credits - 1
							if bGameInPlay = False Then pDMDSplashOneLine Credits & " CREDITS ",3000,cRed
                            If Credits <1 And bFreePlay = 0 Then DOF 125, DOFOff
                            ResetForNewGame()
							'PlayModeMusic
                        End If
                    Else
                        ' Not Enough Credits to start a game.
							bDelayIntro = True
							if bAttractMode Then StopAttractMode
							PlaySound "VO_AddCredits2"
							ClearPupAttractMessages
							bSupressAttractMsg = True
							DMDQueue.Add "bSupressAttractMsg = False-"&Gametime,"bSupressAttractMsg = False",95,3100,0,0,0,True
						if bGameInPlay = False Then pDMDSplashOneLine " INSERT COIN ",3000,cRed
                    End If
                End If
            End If
    End If ' If (GameInPlay)

'table keys
'If keycode = RightMagnaSave or keycode = LeftMagnasave Then ShowPost 

If (keycode = RightMagnaSave or keycode = LeftMagnasave) AND (nEddieSaves(CurrentPlayer) > 0 AND Mode(CurrentPlayer,0) <> 0 And bEddieCooling = False) Then EddieAssist

End Sub

