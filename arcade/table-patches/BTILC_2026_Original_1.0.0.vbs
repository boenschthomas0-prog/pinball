Sub CheckWinMode (nShot)
'debug.print "nShot:" & nShot

	Select Case nShot
		Case 0,1,2,7
			AddModescore SCORE_MODE_PROGRESS, "Left"
		Case 3,4
			AddModescore SCORE_MODE_PROGRESS, "Center"
		Case 5,6
			AddModescore SCORE_MODE_PROGRESS, "Right"
	End Select

	LightEffect 8
	PlayModeProgressAudio
	DOF 159, DOFPulse

	CalcModeProgress	' update Mode Progress bar at top of pup

	Select Case Mode(CurrentPlayer,0)
		Case 1

			if ML(1,2,1) >= ModeReq(1,2) AND ML(1,6,1) >= ModeReq(1,6) Then
				WinMode
				Exit Sub
			Elseif nShot = 2 Then
				ML(1,6,0) = 2
			Elseif nShot = 6 Then
				ML(1,2,0) = 2
			End If


		Case 2
			if (ML(2,0,1) + ML(2,1,1) + ML(2,2,1) + ML(2,3,1) + ML(2,4,1) + ML(2,5,1) + ML(2,6,1) + ML(2,7,1)) mod 8 = 0 AND (nMode2Round = nCurrentRound(CurrentPlayer)) Then
				WinMode	
			Elseif (ML(2,0,1) + ML(2,1,1) + ML(2,2,1) + ML(2,3,1) + ML(2,4,1) + ML(2,5,1) + ML(2,6,1) + ML(2,7,1)) mod 8 = 0 Then 
				Debug.print "Damn Boy"
				nMode2Round = nMode2Round + 1
				GeneralPupQueue.Add "SetModeLights","SetModeLights",84,100,0,0,0,False
				Exit Sub
			End If

		Case 3

			if ML(3,1,1) >= ModeReq(3,1) AND ML(3,2,1) >= ModeReq(3,2) Then
				WinMode
				Exit Sub
			Elseif nShot = 2 Then
				debug.print "CW 3 - 2 "
				ML(3,1,0) = 2
			Elseif nShot = 1 Then
				ML(3,2,0) = 2
			End If
				
		Case 4

			if ML(4,0,1) >= ModeReq(4,0) AND ML(4,6,1) >= ModeReq(4,6) Then
				WinMode
				Exit Sub
			Elseif nShot = 0 Then
				ML(4,6,0) = 2
			Elseif nShot = 6 Then
				ML(4,0,0) = 2
			End If

		Case 5

			if ML(5,1,1) >= ModeReq(5,1) AND ML(5,5,1) >= ModeReq(5,5) Then
				WinMode
				Exit Sub
			Elseif nShot = 1 Then
				ML(5,5,0) = 2
			Elseif nShot = 5 Then
				ML(5,1,0) = 2
			End If
		Case 6
			if ML(6,0,1) >= ModeReq(6,0) AND ML(6,3,1) >= ModeReq(6,3)AND ML(6,4,1) >= ModeReq(6,4) AND ML(6,5,1) >= ModeReq(6,5) Then
				WinMode	
				Exit Sub
			Elseif nShot = 3 Then
				ML(6,4,0) = 2
			Elseif nShot = 4 Then
				ML(6,0,0) = 2
			Elseif nShot = 0 Then
				ML(6,5,0) = 2
			Elseif nShot = 5 Then
				ML(6,3,0) = 2
			End If
	End Select

	if bEddiePlayed Then 
		ModeQueue.Add "PlayModeProgressVideo","PlayModeProgressVideo",62,3100,0,0,0,False
	Else
		ModeQueue.Add "PlayModeProgressVideo","PlayModeProgressVideo",62,100,0,0,0,False
	End If
End Sub


Sub PlayModeProgressVideo
	Dim P, I
	Select Case nCurrentRound(CurrentPlayer)
		Case 1
			I = Int((2 * Rnd))
			I = 1	' test for Joe
			Select Case Mode(CurrentPlayer,0)
				Case 1
					P = ML(1,2,1) + ML(6,2,1) mod 4
					PuPlayer.playevent pDMD,"Mode1","Mode1Progress_" & (P+I) & ".mp4",nPupVideoVolume,62,8,0,""
				Case 2
					P = ML(2,0,1) + ML(2,1,1) + ML(2,2,1) + ML(2,3,1) + ML(2,4,1) + ML(2,5,1) + ML(2,6,1) + ML(2,7,1) 
					PuPlayer.playevent pDMD,"Mode2","Mode2Progress_" & P & ".mp4",nPupVideoVolume,62,8,0,""
				Case 3
					P = ML(3,1,1) + ML(3,2,1) mod 4
					PuPlayer.playevent pDMD,"Mode3","Mode3Progress_" & (P+I) & ".mp4",nPupVideoVolume,62,8,0,""
				Case 4
					P = ML(4,0,1) + ML(4,6,1) mod 4
					debug.print "P:" & P
					PuPlayer.playevent pDMD,"Mode4","Mode4Progress_" & (P+I) & ".mp4",nPupVideoVolume,62,8,0,""
				Case 5
					P = ML(5,1,1) + ML(5,5,1) mod 4
					PuPlayer.playevent pDMD,"Mode5","Mode5Progress_" & (P+I) & ".mp4",nPupVideoVolume,62,8,0,""
				Case 6
					P = (ML(6,0,1) + ML(6,3,1) + ML(6,4,1) + ML(6,5,1)) mod 4
					PuPlayer.playevent pDMD,"Mode6","Mode6Progress_" & (P+I) & ".mp4",nPupVideoVolume,62,8,0,""
			End Select

		Case 2
			Select Case Mode(CurrentPlayer,0)
				Case 1
					P = ML(1,2,1) + ML(6,2,1)
					PuPlayer.playevent pDMD,"Mode1","Mode1Progress_" & P & ".mp4",nPupVideoVolume,62,8,0,""
				Case 2
					P = ML(2,0,1) + ML(2,1,1) + ML(2,2,1) + ML(2,3,1) + ML(2,4,1) + ML(2,5,1) + ML(2,6,1) + ML(2,7,1) 
					PuPlayer.playevent pDMD,"Mode2","Mode2Progress_" & P & ".mp4",nPupVideoVolume,62,8,0,""
				Case 3
					P = ML(3,1,1) + ML(3,2,1)
