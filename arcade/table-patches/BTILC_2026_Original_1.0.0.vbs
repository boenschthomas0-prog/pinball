'========================================================
' LIGHTNING BALLS
'========================================================
Const LightningFollowerCount = 9
Const LightningFrameStart = 1     ' first usable frame (LB_1)
Const LightningFrameEnd   = 15    ' last usable frame (LB_15)
Const LightningZOffset    = 0
Const LightningXOffset    = 0
Const LightningYOffset    = 0
Dim LightningFollowers()
Dim LightningFrames()
Dim LightningAnimPos
Dim LightningActive
Dim TotalLightningFrames
Dim LastX()
Dim LastY()

'--------------------------------------------------------
' Initialize system (call once in Table_Init)
'--------------------------------------------------------
Sub InitLightningFollowers()
    Dim i, frameNum, idx

    ReDim LightningFollowers(LightningFollowerCount)
    ReDim LightningFrames(0)
    ReDim LastX(LightningFollowerCount)
    ReDim LastY(LightningFollowerCount)

    For i = 1 To LightningFollowerCount
        On Error Resume Next
        Set LightningFollowers(i) = Eval("LightningFollower" & i)
        On Error GoTo 0
        If Not LightningFollowers(i) Is Nothing Then
            LightningFollowers(i).Visible = False
            LightningFollowers(i).IntensityScale = 0
            LastX(i) = 0
            LastY(i) = 0
        End If
    Next

    ' Build frame list (LB_1 → LB_15)
    idx = 0
    For frameNum = LightningFrameStart To LightningFrameEnd
        ReDim Preserve LightningFrames(idx)
        LightningFrames(idx) = "LB_" & frameNum
        idx = idx + 1
    Next
    TotalLightningFrames = idx

    ' Ensure editor timer exists and is configured
    tFlameFollow.Interval = 5
    tFlameFollow.Enabled = False

    LightningActive = False
End Sub

'--------------------------------------------------------
' Start / Stop control for lightning
'--------------------------------------------------------
Sub StartLightningFollowers()
    LightningActive = True
    LightningAnimPos = 0
    tFlameFollow.Enabled = True
End Sub

Sub StopLightningFollowers()
    Dim i
    LightningActive = False
    tFlameFollow.Enabled = False
    For i = 1 To LightningFollowerCount
        If Not LightningFollowers(i) Is Nothing Then
            LightningFollowers(i).Visible = False
            LightningFollowers(i).IntensityScale = 0
        End If
    Next
End Sub



'--------------------------------------------------------
' Timer updates animation, rotation + ball tracking
'--------------------------------------------------------
Sub tFlameFollow_Timer()
    On Error Resume Next
    If Not LightningActive Then Exit Sub

    ' Advance animation frame
    If TotalLightningFrames > 0 Then
        LightningAnimPos = (LightningAnimPos + 1) Mod TotalLightningFrames
    End If

    Dim b, i, dx, dy, angRad, angDeg
    i = 1

    For Each b In GetBalls()
        If Not b Is Nothing Then
            ' only for rolling balls (avoid captive)
            If b.Z < 40 Then
                If i <= LightningFollowerCount Then
                    If Not LightningFollowers(i) Is Nothing Then
                        dx = b.X - LastX(i)
                        dy = b.Y - LastY(i)

                        If Abs(dx) + Abs(dy) > 0.5 Then
                            angRad = Atan2(dy, dx)
                            angDeg = angRad * 57.2957795130823
                            LightningFollowers(i).RotZ = angDeg + 270
                        Else
                            LightningFollowers(i).RotZ = 0
                        End If

                        LastX(i) = b.X
                        LastY(i) = b.Y

                        ' dynamic trail distance by speed
                        Dim speed, trailDist
                        speed = Sqr((dx * dx) + (dy * dy))
                        trailDist = -75 - (speed * 0.4)

                        ' clamp trail
                        If trailDist < -80 Then trailDist = -80
                        If trailDist > -10 Then trailDist = -10

                        With LightningFollowers(i)
                            .Visible = True
                            .X = b.X
                            .Y = b.Y
                            .Z = b.Z + LightningZOffset
                            .ImageA = LightningFrames(LightningAnimPos)
                            .IntensityScale = 1
                        End With
                    End If
                    i = i + 1
                End If
            End If
        End If
    Next

    ' Hide any unused followers
    For i = i To LightningFollowerCount
        If Not LightningFollowers(i) Is Nothing Then LightningFollowers(i).Visible = False
    Next

    On Error GoTo 0
End Sub


'====================================================
' GUARDIAN FLYING
'====================================================

'-------------------------
' CONFIG
'-------------------------

Const GuardHomeX = 497.1737
Const GuardHomeY = 155.8722
Const GuardHomeZ = 130

Const GuardDepartX = 442.8601
Const GuardDepartY = 1429.434
Const GuardDepartZ = 90

Const GuardDoorOpenRotX = 110
Const GuardDoorClosedRotX = 0

' pause tuning
Const GuardPauseChance = 0.015
Const GuardPauseHoldMin = 600
Const GuardPauseHoldMax = 1400

Const GuardBaseSpeed = 0.035
Const GuardSpeedEase = 0.06

'-------------------------
' STATE
'-------------------------

Dim GuardAngle
Dim GuardOrbitRadius
Dim GuardReturning
Dim GuardDeparting
Dim GuardPrevX, GuardPrevY
Dim GuardDelayActive

Dim GuardPaused
Dim GuardPauseTime
Dim GuardSpeed
Dim GuardTargetSpeed

'====================================================
' CALLS
'====================================================

Sub GuardSequence_Start()

    guard.X = GuardHomeX
    guard.Y = GuardHomeY
    guard.Z = GuardHomeZ
    guard.Visible = True

    GuardPrevX = guard.X
    GuardPrevY = guard.Y

    GuardAngle = 0
    GuardOrbitRadius = 0
    GuardReturning = False
    GuardDeparting = True
    GuardPaused = False

    GuardSpeed = GuardBaseSpeed
    GuardTargetSpeed = GuardBaseSpeed

    guarddoor001.RotX = GuardDoorClosedRotX

    GuardFlyTimer.Enabled = False
    GuardDelayTimer.Interval = 1500
    GuardDelayTimer.Enabled = True

End Sub

Sub GuardSequence_Stop()
	'if bMidnightMadnessMode Then Exit Sub

    GuardDelayTimer.Enabled = False
    GuardPaused = False

    GuardReturning = True
    GuardDeparting = False
    GuardTargetSpeed = GuardBaseSpeed

End Sub

'====================================================
' DELAY TIMER
'====================================================

Sub GuardDelayTimer_Timer()

    GuardDelayTimer.Enabled = False
    guarddoor001.RotX = GuardDoorOpenRotX

    GuardFlyTimer.Interval = 15
    GuardFlyTimer.Enabled = True

End Sub

'====================================================
' GUARD FLY TIMER
'====================================================

Sub GuardFlyTimer_Timer()

    Dim dx, dy

    '---------------------------------
    ' SMOOTH SLOW DOWN
    '---------------------------------
    GuardSpeed = GuardSpeed + (GuardTargetSpeed - GuardSpeed) * GuardSpeedEase

    '---------------------------------
    ' DEPARTING
    '---------------------------------
    If GuardDeparting And Not GuardReturning Then

        guard.X = guard.X + (GuardDepartX - guard.X) * 0.08
        guard.Y = guard.Y + (GuardDepartY - guard.Y) * 0.08
        guard.Z = guard.Z + (GuardDepartZ - guard.Z) * 0.08

        If Abs(guard.X - GuardDepartX) < 2 _
        And Abs(guard.Y - GuardDepartY) < 2 _
        And Abs(guard.Z - GuardDepartZ) < 2 Then

            guard.X = GuardDepartX
            guard.Y = GuardDepartY
            guard.Z = GuardDepartZ

            GuardDeparting = False
            GuardAngle = 0
            GuardOrbitRadius = 0
        End If

    '---------------------------------
    ' ORBITING
    '---------------------------------
    ElseIf Not GuardReturning Then

        ' pause logic
        If GuardOrbitRadius >= 1 Then
            If GuardTargetSpeed = GuardBaseSpeed Then
                If Rnd < GuardPauseChance Then
                    GuardTargetSpeed = 0
                    GuardPauseTime = GuardPauseHoldMin + Rnd * (GuardPauseHoldMax - GuardPauseHoldMin)
                End If
            Else
                GuardPauseTime = GuardPauseTime - GuardFlyTimer.Interval
                If GuardPauseTime <= 0 Then
                    GuardTargetSpeed = GuardBaseSpeed
                End If
            End If
        End If

        GuardAngle = GuardAngle + GuardSpeed

        If GuardOrbitRadius < 1 Then
            GuardOrbitRadius = GuardOrbitRadius + 0.03
            If GuardOrbitRadius > 1 Then GuardOrbitRadius = 1
        End If

        guard.X = GuardDepartX + Cos(GuardAngle) * 260 * GuardOrbitRadius
        guard.Y = GuardDepartY + Sin(GuardAngle * 0.8) * 200 * GuardOrbitRadius
        guard.Z = GuardDepartZ + Sin(GuardAngle * 1.4) * 18

    '---------------------------------
    ' RETURN HOME
    '---------------------------------
    Else

        guard.X = guard.X * 0.85 + GuardHomeX * 0.15
        guard.Y = guard.Y * 0.85 + GuardHomeY * 0.15
        guard.Z = guard.Z * 0.85 + GuardHomeZ * 0.15

        If Abs(guard.X - GuardHomeX) < 2 _
        And Abs(guard.Y - GuardHomeY) < 2 _
        And Abs(guard.Z - GuardHomeZ) < 2 Then

            guard.X = GuardHomeX
            guard.Y = GuardHomeY
            guard.Z = GuardHomeZ

            guarddoor001.RotX = GuardDoorClosedRotX
            guard.Visible = False
            GuardFlyTimer.Enabled = False
        End If

    End If

    '---------------------------------
    ' FACE DIRECTION
    '---------------------------------
    dx = guard.X - GuardPrevX
    dy = guard.Y - GuardPrevY

    If Abs(dx) > 0.01 Or Abs(dy) > 0.01 Then
        guard.RotZ = Atn2(dy, dx) * 57.2958
    End If

    GuardPrevX = guard.X
    GuardPrevY = guard.Y

End Sub


