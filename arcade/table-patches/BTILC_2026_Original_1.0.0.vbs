' ==================================================
' ######## SHADERS and EFFECTS #####################
' ==================================================

' EF = effect name, IN = Intensity ED = effect duration seconds (0 = loop)

' ===== Effects ====
' 0 - None
' 1 - Smoke / Fog
' 2 - Explosion
' 3 - Heat Haze
' 4 - Film Grain
' 5 - Fire
' 6 - Fireworks
' 7 - Shake
' 8 - LIGHTNING
' 9 - Fireworks 2
' 10 - DMD
' 11 - DMD oldFire

' === Stop all shader effects =====



Sub pDMD_Effect_Stop
	if PupDMD_Effects_Enabled = false Then Exit Sub
	PuPlayer.SendMsg "{ ""mt"":301, ""SN"":5, ""FN"":61, ""EF"":0 }"
	pDMD_Effect_Active = False
End Sub

Sub pDMD_Effect(effect,inten,timesec)
	if PupDMD_Effects_Enabled = false Then Exit Sub
	pDMD_EF = effect
	if effect = "stop" then pDMD_EF = 0
	if effect = "none" then pDMD_EF = 0
	if effect = "fog" then pDMD_EF = 1
	if effect = "explosive" then pDMD_EF = 2
	if effect = "haze" then pDMD_EF = 3
	if effect = "grain" then pDMD_EF = 4
	if effect = "fire" then pDMD_EF = 5
	if effect = "fireworks" then pDMD_EF = 6
	if effect = "shake" then pDMD_EF = 7
	if effect = "lightning" then pDMD_EF = 8
	if effect = "fireworks 2" then pDMD_EF = 9
	if effect = "dmd" then pDMD_EF = 10
	if effect = "dmd 2" then pDMD_EF = 11
	PuPlayer.SendMsg "{ ""mt"":301, ""SN"":5, ""FN"":60, ""EF"":"&pDMD_EF&", ""IN"":"&inten&", ""ED"":"&timesec&" }"

End Sub	

