'========================
'  Safe object resolution
'========================
Function TryGetLightByName(nm, ByRef Lout)
    ' Look in inserts and GI lookups
    If gInsertLookup.Exists(nm) Then
        Set Lout = gInsertLookup(nm)
        TryGetLightByName = True
        Exit Function
    End If
    If gGILookup.Exists(nm) Then
        Set Lout = gGILookup(nm)
        TryGetLightByName = True
        Exit Function
    End If
    TryGetLightByName = False
End Function

Function TryGetFlasherByName(nm, ByRef Fout)
    On Error Resume Next
    Set Fout = Eval(nm)   ' evaluate the object by its name in VPX
    If Err.Number <> 0 Then
        Err.Clear
        Set Fout = Nothing
        TryGetFlasherByName = False
    Else
        TryGetFlasherByName = (TypeName(Fout) = "Flasher")
    End If
    On Error GoTo 0
End Function

