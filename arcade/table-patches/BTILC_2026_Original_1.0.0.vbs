Sub CalcModeProgress
	CurrModeCount = ""
	'ModeHitsRequired = ""

	if nSewerOpen(CurrentPlayer) <> 0 Then
		CurrModeCount = 8 - ( SL(CurrentPlayer,1) + SL(CurrentPlayer,2) + SL(CurrentPlayer,3) + SL(CurrentPlayer,4) + SL(CurrentPlayer,5) + SL(CurrentPlayer,6) + SL(CurrentPlayer,7) + SL(CurrentPlayer,8) )
		ModeHitsRequired = 8
		Exit Sub
	End If

	Select Case nMiniWizard(CurrentPlayer,0)
		' Main Modes and Side Modes
		Case 0
		


			Select Case Mode(CurrentPlayer,0)
				Case 0
				CurrModeCount = 0
				ModeHitsRequired = 0
				' Wildman Bash Mode

				' Spinner Mode

				'Mystery

					if LoPanActive = 1 Then
						CurrModeCount = 8 - ( JL(0) + JL(1) + JL(2) + JL(3) + JL(4) + JL(5) + JL(6) + JL(7) )
						ModeHitsRequired = 8
					End If
                
				Case 1
					CurrModeCount =  ( ML(1,2,1) + ML(1,6,1) )
					PlayModeHit (CurrModeCount mod 4)
				Case 2
					CurrModeCount =  ( ML(2,0,1) + ML(2,1,1) + ML(2,2,1) + ML(2,3,1) + ML(2,4,1) + ML(2,5,1) + ML(2,6,1) + ML(2,7,1) mod 8 )
					PlayModeHit (CurrModeCount mod 8)
				Case 3
					CurrModeCount =  ( ML(3,1,1) + ML(3,2,1) )
					PlayModeHit (CurrModeCount mod 4)
				Case 4
					CurrModeCount = ( ML(4,0,1) + ML(4,6,1) )
					PlayModeHit (CurrModeCount mod 4)
				Case 5
					CurrModeCount = ( ML(5,1,1) + ML(5,5,1) )
					PlayModeHit (CurrModeCount mod 4)
				Case 6
					CurrModeCount =  ( ML(6,3,1) + ML(6,4,1) + ML(6,0,1) + ML(6,5,1) )
					PlayModeHit (CurrModeCount mod 4)
			End Select
		' Mini Wizard Options
		Case 1
			CurrModeCount = 8 - ( JL(0) + JL(1) + JL(2) + JL(3) + JL(4) + JL(5) + JL(6) + JL(7) )
			ModeHitsRequired = 8
		Case 2
			CurrModeCount = 8 - ( JL(0) + JL(1) + JL(2) + JL(3) + JL(4) + JL(5) + JL(6) + JL(7) )
			ModeHitsRequired = 8
		Case 3
			CurrModeCount = 8 - ( JL(0) + JL(1) + JL(2) + JL(3) + JL(4) + JL(5) + JL(6) + JL(7) )
			ModeHitsRequired = 8
		Case 4
			CurrModeCount = 8 - ( JL(0) + JL(1) + JL(2) + JL(3) + JL(4) + JL(5) + JL(6) + JL(7) )
			ModeHitsRequired = 8
	End Select

	DisplayModeProgress
End Sub

Sub PlayModeHit (Count)

    If Count > 0 Then
        StartSpinBothDirections 2
    End If

    If ModeHitsRequired > 0 And CurrModeCount >= ModeHitsRequired Then
        StartSpinBothDirections 2
       ' Debug.Print "MODE COMPLETE FLASH"
    End If

    Select Case Count
        Case 1,5
            PlaySound "ModeShotHit1"
        Case 2,6
            PlaySound "ModeShotHit2"
        Case 3,7
            PlaySound "ModeShotHit3"
        Case 4,8
            PlaySound "ModeShotHit4"
    End Select

End Sub


