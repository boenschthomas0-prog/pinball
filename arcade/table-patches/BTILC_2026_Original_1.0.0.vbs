Sub IronTimer_Timer()

    'Update animation
    IronFlash.ImageA = IronFrames(Iron1Pos)
    Iron2Flash.ImageA = IronFrames(Iron2Pos)

    Iron1Pos = (Iron1Pos + 1) MOD IronFrameCount
    Iron2Pos = (Iron2Pos + 1) MOD IronFrameCount

    'Countdown until stop
    IronTimeLeft = IronTimeLeft - IronTimer.Interval

    If IronTimeLeft <= 0 Then
        StopIron
    End If

