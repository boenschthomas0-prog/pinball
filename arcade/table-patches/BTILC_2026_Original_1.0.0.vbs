Dim WizardPhase
Dim WizardStep
Dim WizardSpeed

Sub StartWizardApocalypse()

    WizardPhase = 0
    WizardStep = 0
    WizardSpeed = 180   ' starts slow (dramatic)

    WizardTimer.Interval = WizardSpeed
    WizardTimer.Enabled = True

End Sub

Sub WizardTimer_Timer()

    Select Case WizardPhase

        Case 0
            ' Slow circular pulse
            ForceAllFlashersOff
            WizardStep = WizardStep + 1
            If WizardStep > 4 Then WizardStep = 1

            ObjTargetLevel(WizardStep) = 1
            CallFlasherTimer WizardStep

            ' Ramp speed up over time
            WizardSpeed = WizardSpeed - 8
            If WizardSpeed < 60 Then
                WizardPhase = 1
                WizardSpeed = 40
            End If
            WizardTimer.Interval = WizardSpeed

        Case 1
            ' FULL CHAOS STROBE (final explosion)
            ObjTargetLevel(1) = Rnd
            ObjTargetLevel(2) = Rnd
            ObjTargetLevel(3) = Rnd
            ObjTargetLevel(4) = Rnd

            FlasherFlash1_Timer
            FlasherFlash2_Timer
            FlasherFlash3_Timer
            FlasherFlash4_Timer

            WizardStep = WizardStep + 1
            If WizardStep > 40 Then
                WizardTimer.Enabled = False
                ForceAllFlashersOff
            End If

    End Select

End Sub

