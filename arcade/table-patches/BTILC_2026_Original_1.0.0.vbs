Sub EOB_Bonus_Timer
'debug.print "EOB STEP: " & eob_step
	
' Change this to match displaEOB -XXXX routines so its consistent
	Select Case CurrRound
		Case 1
			if rampcount <> 0 then 
			'debug.print "RAmps:" & FormatScore(int(TmpPoints*EOB_Step))

				Msg1 = RampCount &"  RAMPS @ " & FormatScore(BONUS_RAMPS) &  " = " & FormatScore(int(TmpPoints*EOB_Step))&  " "
