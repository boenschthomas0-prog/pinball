Sub CheckMBS
	if nMind + nBody + nSoul = 3 Then
		'IncreasePlayfieldMultiplier True
		if nMiniWizard(CurrentPlayer,0) = 0 AND bRampOpen(CurrentPlayer) = False AND BallsonPlayfield = 1 Then
			IncreaseBonusMultiplier True
		Elseif BallsonPlayfield > 1 AND bBMBlock = False Then
			bBMBlock = True
			IncreaseBonusMultiplier True
		Else
			AddScore 50000, "Center"
		End If
		ResetMBS
	End If
End Sub

Sub ResetMBS
	nMind = 0
	nBody = 0
	nSoul = 0
End Sub


