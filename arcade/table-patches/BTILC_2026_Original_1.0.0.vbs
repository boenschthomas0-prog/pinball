Sub DetermineCurrentMode

	if Mode(CurrentPlayer,1) = 1 AND Mode(CurrentPlayer,2) = 1 AND Mode(CurrentPlayer,3) = 1 AND Mode(CurrentPlayer,4) = 1 AND Mode(CurrentPlayer,5) = 1 Then
		CurrentMode = 6
	Else
		' UNTIL ALL 5 MODES ARE COMPLETED DO NOT LOAD MODE 6
		Dim InitialMode
		InitialMode = RndNbr(5)
		if bRandomModes = False Then InitialMode = 1

		Select Case InitialMode
			Case 1
				if Mode(CurrentPlayer,1) = 0 Then
					CurrentMode = 1
				Elseif Mode(CurrentPlayer,2) = 0 Then
					CurrentMode = 2 : nMode2Round = 1
				Elseif Mode(CurrentPlayer,3) = 0 Then
					CurrentMode = 3
				Elseif Mode(CurrentPlayer,4) = 0 Then
					CurrentMode = 4
				Elseif Mode(CurrentPlayer,5) = 0 Then
					CurrentMode = 5
				End If
			Case 2
				if Mode(CurrentPlayer,2) = 0 Then
					CurrentMode = 2: nMode2Round = 1
				Elseif Mode(CurrentPlayer,3) = 0 Then
					CurrentMode = 3
				Elseif Mode(CurrentPlayer,4) = 0 Then
					CurrentMode = 4
				Elseif Mode(CurrentPlayer,5) = 0 Then
					CurrentMode = 5
				Elseif Mode(CurrentPlayer,1) = 0 Then
					CurrentMode = 1
				End If
			Case 3
				if Mode(CurrentPlayer,3) = 0 Then
					CurrentMode = 3
				Elseif Mode(CurrentPlayer,4) = 0 Then
					CurrentMode = 4
				Elseif Mode(CurrentPlayer,5) = 0 Then
					CurrentMode = 5
				Elseif Mode(CurrentPlayer,1) = 0 Then
					CurrentMode = 1
				Elseif Mode(CurrentPlayer,2) = 0 Then
					CurrentMode = 2: nMode2Round = 1
				End If
			Case 4
				if Mode(CurrentPlayer,4) = 0 Then
					CurrentMode = 4
				Elseif Mode(CurrentPlayer,5) = 0 Then
					CurrentMode = 5
				Elseif Mode(CurrentPlayer,1) = 0 Then
					CurrentMode = 1
				Elseif Mode(CurrentPlayer,2) = 0 Then
					CurrentMode = 2: nMode2Round = 1
				Elseif Mode(CurrentPlayer,3) = 0 Then
					CurrentMode = 3
				End If
			Case 5
				if Mode(CurrentPlayer,5) = 0 Then
					CurrentMode = 5
				Elseif Mode(CurrentPlayer,1) = 0 Then
					CurrentMode = 1
				Elseif Mode(CurrentPlayer,2) = 0 Then
					CurrentMode = 2: nMode2Round = 1
				Elseif Mode(CurrentPlayer,3) = 0 Then
					CurrentMode = 3
				Elseif Mode(CurrentPlayer,4) = 0 Then
					CurrentMode = 4
