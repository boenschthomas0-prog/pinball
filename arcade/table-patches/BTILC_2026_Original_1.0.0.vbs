			End If
'			Msg3 = nComboCountRoundHigh &" SHOT HIGHEST COMBO @ " & FormatScore(BONUS_COMBO) &  " = " & FormatScore(int(TmpPoints*EOB_Step))
'			PuPlayer.LabelSet pDMD,"Event5C",msg3,1,"{'mt':2,'fonth': "&EOBFontSize&"}"	
		Case 4
			if spinnercount <> 0 then 
			'debug.print "Spinners:" & FormatScore(int(TmpPoints*EOB_Step))
				if EOB_Step = 1 Then Playsound "EBAward"
				Msg4 = SpinnerCount &"  SPINNERS @ " & FormatScore(BONUS_SPINNER) &  " = " & FormatScore(int(TmpPoints*EOB_Step))&  " "
				if bStandAlone Then 
