Sub CheckModesCompleted (Caller)

	Debug.print "Check Modes Completed - BOP: " & ballsonplayfield & "::" &caller

	if ballsonplayfield > 1 Then bWinModeDelayed = True : debug.print "CMC-bWMD" & bWinModeDelayed : Exit Sub

	debug.print "ModesComp:" & nModesCompleted(CurrentPlayer)

	if nModesCompleted(CurrentPlayer) < 7 Then

		Select Case nModesCompleted(CurrentPlayer)
			Case 1
				if nSewerReturn(CurrentPlayer) = 0 AND BallsonPlayfield < 2 Then EnableMagnet:BeaconEffect_BlinkSpin_NeonGreen
			Case 2
				if nMiniWizCompleted(CurrentPlayer) = 0 AND BallsonPlayfield < 2 Then RampDoorOpen "CMC 2"
			Case 3
				if nSewerReturn(CurrentPlayer) = 1 AND BallsonPlayfield < 2 Then EnableMagnet:BeaconEffect_BlinkSpin_NeonGreen
			Case 4
				if nMiniWizCompleted(CurrentPlayer) = 1 AND BallsonPlayfield < 2 Then RampDoorOpen "CMC 4"
			Case 5
				if nSewerReturn(CurrentPlayer) = 2 AND BallsonPlayfield < 2 Then EnableMagnet:BeaconEffect_BlinkSpin_NeonGreen
			Case 6
				if nMiniWizCompleted(CurrentPlayer) = 2 AND BallsonPlayfield < 2 Then RampDoorOpen "CMC 6"
		End Select

	Else

		Select Case nModesCompleted(CurrentPlayer) mod 6
			Case 1
				if nSewerReturn(CurrentPlayer) = 0 AND BallsonPlayfield < 2 Then EnableMagnet:BeaconEffect_BlinkSpin_NeonGreen
			Case 2
				if nMiniWizCompleted(CurrentPlayer) = 0 AND BallsonPlayfield < 2 Then RampDoorOpen "CMC MR 2"
			Case 3
				if nSewerReturn(CurrentPlayer) = 1 AND BallsonPlayfield < 2 Then EnableMagnet:BeaconEffect_BlinkSpin_NeonGreen
			Case 4
				if nMiniWizCompleted(CurrentPlayer) = 1 AND BallsonPlayfield < 2 Then RampDoorOpen "CMC MR 4"
			Case 5
				if nSewerReturn(CurrentPlayer) = 2 AND BallsonPlayfield < 2 Then EnableMagnet:BeaconEffect_BlinkSpin_NeonGreen
			Case 0
				if nMiniWizCompleted(CurrentPlayer) = 2 AND BallsonPlayfield < 2 Then RampDoorOpen "CMC MR 6"
		End Select


	End If
End Sub

