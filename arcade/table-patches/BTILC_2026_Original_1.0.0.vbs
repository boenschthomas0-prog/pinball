Sub CheckEggShenDoor
'	debug.print "CHECK EGG SHEN- " &gametime
	if bSuperMysteryReward(CurrentPlayer) OR bMysteryReward(CurrentPlayer) Then Exit Sub

	if ESL(CurrentPlayer,0) + ESL(CurrentPlayer,1) + ESL(CurrentPlayer,2) + ESL(CurrentPlayer,3) + ESL(CurrentPlayer,4) + ESL(CurrentPlayer,5) + ESL(CurrentPlayer,6) = 7 Then
		'debug.print "Egg Passed"
		'MysteryDoorOpen
		if Diverter2Closed.Collidable = False Then 
			MysteryControllerOpen
			nRubyCount(CurrentPlayer) = nRubyCount(CurrentPlayer) + 1
			UpdateBridgeLights
			UpdateBridgeDOF
			nRubyLights(CurrentPlayer,nRubyCount(CurrentPlayer)) = 1
			if nRubyCount(CurrentPlayer) > 6 Then
				'Debug.print " MEGA MYSTERY"
'				StartEgg
				'MysteryHole.Enabled = True
				bSuperMysteryReward(CurrentPlayer) = True 
				nRubyCount(CurrentPlayer) = 0
				UpdateBridgeLights
			Else
				'debug.print "WTF MAN - " &gametime
				bMysteryReward(CurrentPlayer) = True
			End If
		End If

	End If
End Sub

