Dim RainCnt

Sub RainTimer_Timer()

    If Not RainModeActive Then Exit Sub

    RainCnt = RainCnt + 1
    If RainCnt > 4 Then RainCnt = 1

    Select Case RainCnt

        Case 1
            Rain1.Visible = True
            Rain2.Visible = False
            Rain3.Visible = False
            Rain4.Visible = False

        Case 2
            Rain1.Visible = False
            Rain2.Visible = True
            Rain3.Visible = False
            Rain4.Visible = False

        Case 3
            Rain1.Visible = False
            Rain2.Visible = False
            Rain3.Visible = True
            Rain4.Visible = False

        Case 4
            Rain1.Visible = False
            Rain2.Visible = False
            Rain3.Visible = False
            Rain4.Visible = True

    End Select

End Sub

