Sub Table1_Init()
    LoadEM

	if PlatformOS <> "windows" Then ScorbitActive = 0

	table1.balltrail = False

	Dim i
    bDelayIntro = False
	bSupressAttractMsg = False
	MysteryDoorClose
	QuestDoorClose
	LockDoorClose
    BeaconTimer.Enabled = False
    Primitive020b.visible = False
    Primitive021b.visible = False
    Primitive022b.visible = False
'Impulse Plunger as autoplunger
    Const IMPowerSetting = 38 ' Plunger Power
    Const IMTime = 1.1        ' Time in seconds for Full Plunge
    Set plungerIM = New cvpmImpulseP
    With plungerIM
        .InitImpulseP swplunger, IMPowerSetting, IMTime
        .Random 1.5
        .InitExitSnd SoundFXDOF("fx_kicker", 141, DOFPulse, DOFContactors), SoundFXDOF("fx_solenoid", 141, DOFPulse, DOFContactors)
        .CreateEvents "plungerIM"
    End With

    ' Misc. VP table objects Initialisation, droptargets, animations...
    VPObjects_Init

    ' load saved values, highscore, names, jackpot
    Loadhs
 
	Set cbCenter = New cvpmCaptiveBall
    With cbCenter
        .InitCaptive CapTrigger1, CapWall1, Array(CapKicker1, CapKicker1a), 0
        .NailedBalls = 1
        .ForceTrans = .9
        .MinForce = 3.5
   '     .CreateEvents "cbCenter"
        .Start
    End With
    CapKicker1.CreateSizedBallWithMass BallSize / 2, BallMass

    ' Magnet
    Set mMagnet = New cvpmMagnet
    With mMagnet
        .InitMagnet Magnet, 28
        .GrabCenter = True
        .CreateEvents "mMagnet"
    End With


    ' Turn Table - Spinner disk
    Set ttSpinDisk1 = New cvpmTurnTable
    With ttSpinDisk1
        .InitTurnTable RainDisk1, 40
        .spinCW = True
        .SpinUp = 15
        .SpinDown = 8
        .MotorOn = False
        .CreateEvents "ttSpinDisk1"
    End With

    Set ttSpinDisk2 = New cvpmTurnTable
    With ttSpinDisk2
        .InitTurnTable RainDisk2, 50
        .spinCW = True
        .SpinUp = 20
        .SpinDown = 3
        .MotorOn = False
        .CreateEvents "ttSpinDisk2"
    End With

    Set ttSpinDisk3 = New cvpmTurnTable
    With ttSpinDisk3
        .InitTurnTable RainDisk3, 40
        .spinCW = False
        .SpinUp = 12
        .SpinDown = 6
        .MotorOn = False
        .CreateEvents "ttSpinDisk3"
    End With



	DOF 126, DOFON

   
 'Init main variables
    For i = 1 To MaxPlayers
        Score(i) = 0
        BonusPoints(i) = 0
        nBonusMultiplier(i) = 1
        BallsRemaining(i) = BallsPerGame
        ExtraBallsAwards(i) = 0
    Next


    ' freeplay or coins
   ' bFreePlay = True 'we want coins

	'SwitchMusic "mu_Intro"

    'if bFreePlay = false Then DOF 125, DOFOn

    ' Init main variables and any other flags
    bAttractMode = False
    bOnTheFirstBall = False
    bBallInPlungerLane = False
    bBallSaverActive = False
    bBallSaverReady = False
    bGameInPlay = False
    bMusicOn = True
    BallsOnPlayfield = 0
	bMultiBallMode = False
	'Multiball=false
	bAutoPlunger = False
    BallsInLock = 0
    BallsInHole = 0
	LastSwitchHit = ""
    Tilt = 0
    TiltSensitivity = 6
    Tilted = False
    bJustStarted = True
    ' set any lights for the attract mode
    GiOff
    ' Load table color
    LoadLut
	pupinit
    InitLightningFollowers
	pDMDSetpage pScores
    Pan1Init
    Pan2Init
    Pan3Init
    Pan4Init
    Pan5Init
	CheckPupVersion
    InitFlashers
	CheckOS
    InitSKFlashers
	if ScorbitActive = 0 Then
		Dbg2 "Attract Coming"
		BallHandlingQueue.Add "ResetOverlay","ResetOverlay",24,1000,0,0,0,False		
		'BallHandlingQueue.Add "ResetBackglass","ResetBackglass",24,2000,0,0,0,False	
		DMDQueue.Add "StartAttractMode","StartAttractMode",95,3000,0,0,0,False	
	Else
		Dbg2 "Skipping"
	End If
	' Prevent User From Starting Game Before Pup Loads Properly
	DMDQueue.Add "bGameReady = True","bGameReady = True",95,3050,0,0,0,False


    'StartAttractMode
	'EndOfGame()

