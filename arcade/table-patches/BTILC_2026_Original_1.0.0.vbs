Sub MidnightMadnessTimer_Timer()

	If MadnessActive = False Then Exit Sub

	' FIX: hard reset FIRST to prevent overlap flicker
	ForceAllFlashersOff

	MidnightMadnessTimer.Interval = 60 + Int(Rnd * 140)

	If Rnd < 0.35 Then
		ForceAllFlashersOff
	Else

		Dim i
		For i = 1 To 4
			If Rnd > 0.5 Then
				ObjTargetLevel(i) = 1
			Else
				ObjTargetLevel(i) = 0
			End If
		Next

		FlasherFlash1_Timer
		FlasherFlash2_Timer
		FlasherFlash3_Timer
		FlasherFlash4_Timer

		If Rnd > 0.75 Then Sound_Flash_Relay True, Flasherbase1
		If Rnd > 0.75 Then Sound_Flash_Relay True, Flasherbase2
		If Rnd > 0.75 Then Sound_Flash_Relay True, Flasherbase3
		If Rnd > 0.75 Then Sound_Flash_Relay True, Flasherbase4

	End If

	If GameTime >= MadnessEndTime Then
		StopMidnightLights
	End If

End Sub

Sub StopMidnightLights()

MidnightMadnessTimer.Enabled = False
MadnessActive = False

' Reset
Dim i
For i = 1 To 4
    ObjTargetLevel(i) = 0
    ObjLevel(i) = 0
Next

FlasherFlash1_Timer
FlasherFlash2_Timer
FlasherFlash3_Timer
FlasherFlash4_Timer

End Sub
