Dim BarStep
Dim BarPhase
Dim LookCount
Dim LookDir 

Sub InitBar()
	if nPCMod = 0 Then Exit Sub
    BarStep = 1
    BarPhase = 0
    LookCount = 0
    LookDir = 1
    UpdateBar
End Sub

Sub BarTrig_Hit()
    If BarPhase = 0 Then
        BarPhase = 1
        BarStep = 1
        PlaySound "CW_Open"

        BarTimer.Interval = 100
        	if nPCMod > 0 Then BarTimer.Enabled = True
    End If
End Sub

Sub BarTimer_Timer()

    Select Case BarPhase

        ' =================
        ' OPEN
        ' =================
        Case 1
            BarTimer.Interval = 100
            BarStep = BarStep + 1

            If BarStep >= 4 Then
                BarStep = 5
                BarPhase = 2
                LookCount = 0
                LookDir = 1
            End If

        ' =================
        ' LOOK
        ' =================
        Case 2
            BarTimer.Interval = 340

            BarStep = BarStep + LookDir

            ' Hit right side
            If BarStep >= 8 Then
                BarStep = 8
                LookDir = -1
                LookCount = LookCount + 1
            End If

            ' Hit left side
            If BarStep <= 5 Then
                BarStep = 5
                LookDir = 1
                LookCount = LookCount + 1
            End If

            ' 1 full left-right cycle
            If LookCount >= 1 Then
                PlaySound "CW_Close"

                BarStep = 3
                BarPhase = 3
                BarTimer.Interval = 100
            End If

        ' =================
        ' CLOSING
        ' =================
        Case 3
            BarTimer.Interval = 100
            BarStep = BarStep - 1

            If BarStep <= 1 Then
                BarStep = 1
                BarPhase = 0
                BarTimer.Enabled = False
            End If

    End Select

    	if nPCMod > 0 Then UpdateBar
End Sub

Sub UpdateBar()
	if nPCMod = 0 Then Exit Sub

    bar001.Visible = (BarStep = 1)
    bar002.Visible = (BarStep = 2)
    bar003.Visible = (BarStep = 3)
    bar004.Visible = (BarStep = 4)
    bar005.Visible = (BarStep = 5)
    bar006.Visible = (BarStep = 6)
    bar007.Visible = (BarStep = 7)
    bar008.Visible = (BarStep = 8)

End Sub

