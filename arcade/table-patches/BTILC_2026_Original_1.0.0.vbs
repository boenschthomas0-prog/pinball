	if bMidnightMadnessMode Then Exit Sub

	bAddSewerTimeReady = False

	nSewerTime(CurrentPlayer) = nSewerTime(CurrentPlayer) + 30
	'debug.print "Add Sewer Time : " &  nSewerTime(CurrentPlayer)

	if nSewerTime(CurrentPlayer) > 240 Then
		nSewerTime(CurrentPlayer) = 240
		'debug.print "Should have played prok chop JACKPOT VIDEO"
		AwardPorkchopJackpot
	Else
		if caller = 1 Then
			DOFQueue.Add "DOF 220, DOFON","DOF 220, DOFON",63,0,0,0,0,False
			DOFQueue.Add "DOF 220, DOFOFF","DOF 220, DOFOFF",63,2500,0,0,0,False
			PlaySecretPassageVideo
		End If

		if caller = 2 Then
			DOFQueue.Add "DOF 273, DOFON","DOF 273, DOFON",63,0,0,0,0,False
			DOFQueue.Add "DOF 273, DOFOFF","DOF 273, DOFOFF",63,2500,0,0,0,False
			PlaySecretPassageVideo2
		End If

		'ResetSewerTime
	End If

End Sub

