'*****************************
'SkullAnimation
'*****************************

Dim skFrame, skRunning, skTimeElapsed
Dim EyeLevel, EyeDir, EyeState
Dim LastEyeLevel
Dim skFrameStep

Sub InitSKFlashers()

    sk001.Visible = False
    sk002.Visible = False

    skeye1.Visible = False
    skeye2.Visible = False
    skeye3.Visible = False
    skeye4.Visible = False

    skeye1.IntensityScale = 0
    skeye2.IntensityScale = 0
    skeye3.IntensityScale = 0
    skeye4.IntensityScale = 0

    flasherbloomgracie.Visible = False
    flasherbloomgracie.IntensityScale = 0

    'gracielight.Visible = False

    SKTimer.Enabled = False
    skRunning = False

End Sub


Sub StartSKFlashers()
    If skRunning Then Exit Sub

    skFrame = 1
    skTimeElapsed = 0
    skRunning = True
    skFrameStep = 0

    EyeLevel = 0
    EyeDir = 1
    EyeState = 0
    LastEyeLevel = -1

    sk001.Visible = True
    sk002.Visible = True

    skeye1.IntensityScale = 0
    skeye2.IntensityScale = 0
    skeye3.IntensityScale = 0
    skeye4.IntensityScale = 0

    skeye1.Visible = True
    skeye2.Visible = True
    skeye3.Visible = True
    skeye4.Visible = True

    flasherbloomgracie.Visible = True
    flasherbloomgracie.IntensityScale = 0

    gracielight.Visible = True

    SKTimer.Enabled = True
End Sub


Sub SKTimer_Timer()

    If Not skRunning Then Exit Sub

    ' ***************************************************
    If skTimeElapsed >= 60000 Then
        skRunning = False
        SKTimer.Enabled = False

        sk001.Visible = False
        sk002.Visible = False
        skeye1.Visible = False
        skeye2.Visible = False
        skeye3.Visible = False
        skeye4.Visible = False
        flasherbloomgracie.Visible = False
        gracielight.Visible = False
        Exit Sub
    End If
    ' ***************************************************

    Dim img
    img = "bfl_" & skFrame

    sk001.ImageA = img
    sk002.ImageA = img

    skFrameStep = skFrameStep + 1
    If skFrameStep >= 2 Then
        skFrame = skFrame + 1
        skFrameStep = 0
    End If

    If skFrame > 48 Then skFrame = 1

    Select Case EyeState

        Case 0
            EyeLevel = EyeLevel + 0.05
            If EyeLevel >= 1 Then
                EyeLevel = 1
                EyeState = 1
            End If

        Case 1
            EyeLevel = EyeLevel + (EyeDir * 0.05)

            If EyeLevel >= 1 Then
                EyeLevel = 1
                EyeDir = -1
            ElseIf EyeLevel <= 0.4 Then
                EyeLevel = 0.4
                EyeDir = 1
            End If

            If skTimeElapsed >= 60000 Then EyeState = 2

        Case 2
            EyeLevel = EyeLevel - 0.05
            If EyeLevel <= 0 Then EyeLevel = 0

    End Select

    If EyeLevel <> LastEyeLevel Then
        skeye1.IntensityScale = EyeLevel
        skeye2.IntensityScale = EyeLevel
        skeye3.IntensityScale = EyeLevel
        skeye4.IntensityScale = EyeLevel
        flasherbloomgracie.IntensityScale = EyeLevel
        LastEyeLevel = EyeLevel
    End If

'    ' Gracie blink: normal first 30s, faster last 30s
    If skTimeElapsed < 45000 Then
        If (skTimeElapsed Mod 400) < SKTimer.Interval Then
            gracielight.Visible = Not gracielight.Visible
        End If
    Else
        If (skTimeElapsed Mod 200) < SKTimer.Interval Then
            gracielight.Visible = Not gracielight.Visible
        End If
    End If

    skTimeElapsed = skTimeElapsed + SKTimer.Interval

End Sub


Sub StopSKFlashers()

    skRunning = False
    SKTimer.Enabled = False
    sk001.Visible = False
    sk002.Visible = False
    skeye1.Visible = False
    skeye2.Visible = False
    skeye3.Visible = False
    skeye4.Visible = False
    flasherbloomgracie.Visible = False
    gracielight.Visible = False

End Sub

