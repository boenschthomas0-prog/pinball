'*******************************************
'  ZINS: Instruction Mode
'*******************************************
'===============================
' Instruction Mode 
'===============================
Dim gInstructionMode : gInstructionMode = False

' --- Light state stores for snapshot/restore ---
Dim gSavedInserts : Set gSavedInserts = CreateObject("Scripting.Dictionary")
Dim gSavedGI      : Set gSavedGI      = CreateObject("Scripting.Dictionary")

' --- Lookups by name (Light objects) ---
Dim gInsertLookup : Set gInsertLookup = CreateObject("Scripting.Dictionary") ' inserts only
Dim gGILookup     : Set gGILookup     = CreateObject("Scripting.Dictionary") ' GI only

' --- Active feature state ---
Dim gFeatureKeys          ' ordered array of feature keys
Dim gFeatureIndex           ' current feature index
Dim gSeqSteps               ' current feature's steps array
Dim gSeqStepIdx             ' index within steps
Dim gBlinkState : gBlinkState = True
Dim gBlinkGroup : Set gBlinkGroup = CreateObject("Scripting.Dictionary") ' lights that blink this step
Dim gGIOn       : Set gGIOn       = CreateObject("Scripting.Dictionary") ' GI lights currently left on
Dim gActiveFlasherName       ' string name of flasher for current feature

' --- Timers ---
' gBlinkTimer.Enabled=False, Interval ~ 150
' gInstrSeqTimer.Enabled=False, Interval ~ 250

'========================
'  Initialization helpers
'========================
Sub BuildInsertLookup()
    Dim L
    gInsertLookup.RemoveAll
    For Each L In cInserts                 ' uses your existing table collection to discover inserts
        If TypeName(L) = "Light" Then Set gInsertLookup(L.Name) = L
    Next
End Sub

Sub BuildGILookup()
    Dim L
    gGILookup.RemoveAll
    For Each L In cGI                      ' uses your existing table collection to discover GI
        If TypeName(L) = "Light" Then Set gGILookup(L.Name) = L
    Next
End Sub

'========================
'  Snapshot / Restore PF
'========================
Sub Instr_SnapshotLights()
    Dim L
    gSavedInserts.RemoveAll
    For Each L In cInserts
        If TypeName(L) = "Light" Then
            gSavedInserts(L.Name) = Array(L.State, L.IntensityScale)
        End If
    Next

    gSavedGI.RemoveAll
    For Each L In cGI
        If TypeName(L) = "Light" Then
            gSavedGI(L.Name) = Array(L.State, L.IntensityScale)
        End If
    Next
End Sub

Sub Instr_AllInsertsOff()
    Dim L
    For Each L In cInserts
        If TypeName(L) = "Light" Then
            L.State = 0 : L.IntensityScale = 0
        End If
    Next
End Sub

Sub Instr_AllGIOff()
    Dim L
    For Each L In cGI
        If TypeName(L) = "Light" Then
            L.State = 0 : L.IntensityScale = 0
        End If
    Next
End Sub

Sub Instr_AllLightsOff()
    Instr_AllInsertsOff
    Instr_AllGIOff
End Sub

Sub Instr_RestoreLights()
    Dim L, s
    For Each L In cInserts
        If TypeName(L) = "Light" Then
            If gSavedInserts.Exists(L.Name) Then
                s = gSavedInserts(L.Name)
                L.State = s(0)
                L.IntensityScale = s(1)
            End If
        End If
    Next

    For Each L In cGI
        If TypeName(L) = "Light" Then
            If gSavedGI.Exists(L.Name) Then
                s = gSavedGI(L.Name)
                L.State = s(0)
                L.IntensityScale = s(1)
            End If
        End If
    Next
End Sub

'========================
'  Begin / End Mode
'========================
Sub BeginInstructionMode()
    If gInstructionMode  Then Exit Sub
    If (ballsonplayfield < 2 AND bBallInPlungerLane = True) OR bAttractMode Then 

		if bAttractMode Then bReturnAttractMode = True: StopAttractMode

		gInstructionMode = True

	'    ' Pause the ROM
	'    On Error Resume Next : Controller.Pause = True : On Error GoTo 0

		BuildInsertLookup
		BuildGILookup
		Instr_DefineFeatures
		Instr_DefineContent

		Instr_SnapshotLights
		Instr_AllLightsOff

		gFeatureIndex = 0
		Instr_ShowFeatureByIndex gFeatureIndex
	End If
End Sub

Sub EndInstructionMode()
debug.print "END : Hiding Instruction Cards"
    If Not gInstructionMode Then Exit Sub
	ReturnState
	ReturnJackTargets
	EndBashMode
	gInstructionMode = False
	StopBeacon

	'BallHandlingQueue.Add "gInstructionMode = False","gInstructionMode = False",20,250,0,0,0,False
    

    gBlinkTimer.Enabled = False
    gInstrSeqTimer.Enabled = False

    Instr_HideAllFlashers
    Instr_TurnOffGIActive

    Instr_RestoreLights

   ' On Error Resume Next : Controller.Pause = False : On Error GoTo 0

    gSavedInserts.RemoveAll
    gSavedGI.RemoveAll


	if bReturnAttractMode Then bReturnAttractMode = False : StartAttractMode

	BallHandlingQueue.Add "ReturnState","ReturnState",20,250,0,0,0,False
End Sub

'========================
'  Feature switching
'========================
Sub Instr_NextFeature()
    If Not gInstructionMode Then Exit Sub
	ReturnState
    gFeatureIndex = (gFeatureIndex + 1) Mod (UBound(gFeatureKeys) + 1)
    Instr_ShowFeatureByIndex gFeatureIndex
End Sub

Sub Instr_PrevFeature()
    If Not gInstructionMode Then Exit Sub
	ReturnState
    Dim n : n = UBound(gFeatureKeys) + 1
    gFeatureIndex = (gFeatureIndex - 1 + n) Mod n
    Instr_ShowFeatureByIndex gFeatureIndex
End Sub

Sub Instr_ShowFeatureByIndex(idx)
    Dim key : key = gFeatureKeys(idx)
    Instr_ShowFeatureByKey key
End Sub

Sub Instr_ShowFeatureByKey(key)
    If Not gInstructionMode Then Exit Sub

    ' stop previous
    gBlinkTimer.Enabled = False
    gInstrSeqTimer.Enabled = False

    ' clear PF baseline
    Instr_AllInsertsOff
    Instr_TurnOffGIActive
    Instr_HideAllFlashers

    ' GI for this feature
    Instr_TurnOnGI key

    ' Flashers (multiple) for this feature
    If gFlashersByFeature.Exists(key) Then
        Instr_ShowFlashers gFlashersByFeature(key)
    End If

    ' Sequence for this feature
    If gSeqs.Exists(key) Then
        gSeqSteps = gSeqs(key)
        gSeqStepIdx = 0
        Instr_ApplyStep gSeqSteps(gSeqStepIdx)
    End If
End Sub

'========================
'  GI control (arrays)
'========================
Sub Instr_TurnOnGI(key)
    Dim arr, i, nm, L
    gGIOn.RemoveAll
    If gGIByFeature.Exists(key) Then
        arr = gGIByFeature(key)
        If IsArray(arr) Then
            For i = LBound(arr) To UBound(arr)
                nm = CStr(arr(i))
                If TryGetLightByName(nm, L) Then
                    If TypeName(L) = "Light" Then
                        L.State = 1 : L.IntensityScale = 1
                        If Not gGIOn.Exists(nm) Then Set gGIOn(nm) = L
                    End If
                End If
            Next
        End If
    End If
End Sub

Sub Instr_TurnOffGIActive()
    Dim v, L
    For Each v In gGIOn.Items
        Set L = v
        If TypeName(L) = "Light" Then
            L.State = 0 : L.IntensityScale = 0
        End If
    Next
    gGIOn.RemoveAll
End Sub

'========================
'  Flasher control
'========================
Sub Instr_HideAllFlashers()

    Dim v, F
    For Each v In gActiveFlashers.Items
        Set F = v
        If TypeName(F) = "Flasher" Then F.Visible = False
    Next
    gActiveFlashers.RemoveAll
End Sub

Sub Instr_ShowFlashers(arr)
    Dim i, nm, F
    If IsArray(arr) Then
        For i = LBound(arr) To UBound(arr)
            nm = CStr(arr(i))
            If TryGetFlasherByName(nm, F) Then
                If TypeName(F) = "Flasher" Then
                    F.Visible = True
                    If Not gActiveFlashers.Exists(nm) Then Set gActiveFlashers(nm) = F
                End If
            End If
        Next
    End If
End Sub



Sub Instr_SetInsertsSolid(arr)
    Dim i, nm, L
    If IsArray(arr) Then
        For i = LBound(arr) To UBound(arr)
            nm = CStr(arr(i))
            If TryGetLightByName(nm, L) Then
                If TypeName(L) = "Light" Then
                    L.State = 1 : L.IntensityScale = 1
                End If
            End If
        Next
    End If
End Sub

Sub Instr_SetBlinkGroup(arr)
    Dim i, nm, L
    If IsArray(arr) Then
        For i = LBound(arr) To UBound(arr)
            nm = CStr(arr(i))
            If TryGetLightByName(nm, L) Then
                If TypeName(L) = "Light" Then
                    If Not gBlinkGroup.Exists(nm) Then Set gBlinkGroup(nm) = L
                    L.State = 1 : L.IntensityScale = 1
                End If
            End If
        Next
    End If
End Sub

Sub gInstrSeqTimer_Timer()
    gInstrSeqTimer.Enabled = False
    If Not gInstructionMode Then Exit Sub
    If IsArray(gSeqSteps) Then
        gSeqStepIdx = (gSeqStepIdx + 1) Mod (UBound(gSeqSteps) + 1)
'		Debug.print "----------------------------"
'		Debug.print "Main:" & gSeqStepIdx
'		Debug.print "----------------------------"
        Instr_ApplyStep gSeqSteps(gSeqStepIdx)
    End If
End Sub

Sub gBlinkTimer_Timer()
    If Not gInstructionMode Then
        gBlinkTimer.Enabled = False
        Exit Sub
    End If
    gBlinkState = Not gBlinkState

    Dim v, L
    For Each v In gBlinkGroup.Items
        Set L = v
        If TypeName(L) = "Light" Then
            If gBlinkState Then
                L.State = 1 : L.IntensityScale = 1
            Else
                L.State = 0 : L.IntensityScale = 0
            End If
        End If
    Next
End Sub

'========================
'  Feature definitions
'========================
' Each step: Array( holdMs, solidInsertNames(), blinkInsertNames() )

' --- Define features by key order ---
Sub Instr_DefineFeatures()
    gFeatureKeys = Array("Start", "Quest" ,"EddieAssist", "MBS", "JACK", "WANG", "GRACIE", "EGGSHEN", "Wildman", "SuperSpinners", "SecretPassage", "Sewer", "CaptiveBall", "Henry", "MiniWiz")  ' simple direct assignment
End Sub

' --- Sequences: Dictionary key -> steps array ---
Dim gSeqs : Set gSeqs = CreateObject("Scripting.Dictionary")
' --- GI lists: Dictionary key -> array of GI light names to keep on ---
Dim gGIByFeature : Set gGIByFeature = CreateObject("Scripting.Dictionary")
' --- Flashers: Dictionary key -> flasher object name (String) ---
Dim gFlashersByFeature : Set gFlashersByFeature = CreateObject("Scripting.Dictionary")


'========================
'  Sequence engine
'========================
' Step = Array( holdMs, solidArr(), blinkArr() )
Sub Instr_ApplyStep(stepArr)
    Dim holdMs, solidArr, blinkArr

    holdMs   = stepArr(0)
    solidArr = stepArr(1)
    blinkArr = stepArr(2)

    ' Clear inserts (but leave GI as-is)
    Instr_AllInsertsOff

    ' Rebuild blink group
    gBlinkGroup.RemoveAll

    ' Solid ON
    Call Instr_SetInsertsSolid(solidArr)

    ' Blink group
    Call Instr_SetBlinkGroup(blinkArr)

    ' Start blink if needed
    gBlinkState = True
    gBlinkTimer.Enabled = (gBlinkGroup.Count > 0)

    ' Arm next step
    If IsNumeric(holdMs) And holdMs > 0 Then
        gInstrSeqTimer.Interval = holdMs
    Else
        gInstrSeqTimer.Interval = 250
    End If
    gInstrSeqTimer.Enabled = True

debug.print "SEQUENCE: " & gFeatureIndex
		Select Case gFeatureIndex
			Case 0

			Case 1
				Select Case gSeqStepIdx
					Case 0
						Debug.print "QDS: " & QuestDoor_State
						if QuestDoor_State <> 1 Then QuestDoorOpen
                        RulesArrowTimer.Enabled = True
				End Select
			Case 2
				if gSeqStepIdx = 0 Then
					E1.Visible = True
					E2.Visible = True
					E3.Visible = True
					E4.Visible = True
                    RulesArrowTimer.Enabled = True
				End If

			Case 3
                 RulesArrowTimer.Enabled = True
			Case 4
                 RulesArrowTimer.Enabled = True
					Select Case gSeqStepIdx
						Case 0
							InstrJackDT
						Case 1
							InstrJackDT
						Case 2
							InstrJackDT
						Case 3
							InstrJackDT
						Case 4
							DTRaise 1
							DTRaise 2
							DTRaise 3
							DTRaise 4
							'ReturnState
						Case 5
                         
					End Select

			Case 5
				  RulesArrowTimer.Enabled = True
			Case 6
				  RulesArrowTimer.Enabled = True
			Case 7
				If MystCon = 0 AND gSeqStepIdx = 8 AND bInstMystery = False Then MysteryControllerOpen

			Case 8
				if gSeqStepIdx = 0 AND bashhitTrig.Enabled = False Then StartBashMode
                RulesArrowTimer.Enabled = True
			Case 9
                RulesArrowTimer.Enabled = True

				if gSeqStepIdx = 1 Then
					RotateStorms_SuperSpinners
					StartSpinnerLightning
					ViewSpinner5
				End If

			Case 10
				RulesArrowTimer.Enabled = True

			Case 11

                RulesArrowTimer.Enabled = True
				Select Case gSeqStepIdx
					Case 0
						if Door006.Visible = False Then OpenDoor
					Case 2
						Target013.isdropped = 1
						Playsound "Drop_Target_Down_1"
					Case 4
						Target012.isdropped = 1
						Playsound "Drop_Target_Down_1"
					Case 6
						Target011.isdropped = 1
						Playsound "Drop_Target_Down_1"
					Case 8
						Playsound "Drop_Target_Reset_1"
						Target013.isdropped = 0
						Target011.isdropped = 0
						Target012.isdropped = 0
				End Select			


			Case 12
				if gSeqStepIdx = 10 AND LockCon = 0 AND OrbitKicker.Enabled = False Then lockcontrolleropen

			Case 13

			Case 14
                 RulesArrowTimer.Enabled = True
				if RampDoor.Collidable Then rampdooropen "Instr"
		End Select
End Sub

