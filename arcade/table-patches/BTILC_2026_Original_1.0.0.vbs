				Else
					PuPlayer.LabelSet pDMD,"Event5E",msg5,1,"{'mt':2,'fonth': "&(EOBFontSize)&", 'xpos': 20, 'ypos': 61}"	
				End If
			Else
				if EOB_Step = 1 Then Playsound "zerotally"
			End If


	End Select

	TotalBonus = TotalBonus + TmpPoints

'	debug.print "Total Bonus = " & TotalBonus
	EOB_Step = EOB_Step + 1
	if EOB_Step > 10 Then EOB_Bonus.Enabled = False 
End Sub


