	Debug.print "Check Gracie:" & LastSwitchHit
	if (LastSwitchHit = "LeftRamp" AND bGracieGauntlet = False) Then
		GracieCount = GracieCount + 1
		if GracieCount < 10 Then
			AudioQueue.Add "PlayGracieAudio","PlayGracieAudio",20,100,0,0,0,False
		Else
			StartGracieGauntlet
			DOFQueue.Add "DOF 208, DOFON","DOF 208, DOFON",81,0,0,0,0,False
			DOFQueue.Add "DOF 208, DOFOFF","DOF 208, DOFOFF",81,1500,0,0,0,False
		End If
	Else
		ResetGracieCount
	End If
End Sub

Sub PlayGracieAudio
    If bGracieGauntlet Then Exit Sub
	if GracieCount < 2 Then Exit Sub
	PlaySound "vo_Gracie_" & GracieCount, 0 , fCalloutVolume
End Sub

Sub StartGracieGauntlet
    SkullLight002.state = 2
	if bGracieGauntlet Then Exit Sub
    bGracieGauntlet = True 
    StartSKFlashers
	DisplayGracieOverlay
	SewerCountDown = 60
	SewerTimer.Enabled = True
	DisplaySewerTime

	GracieGauntletTimer.Enabled = 1
	StartGracieVideo
	'PuPlayer.playevent pDMD,"Misc","GracieGLoop.mp4",nPupVideoVolume,20,6,0,""
	'GeneralPupQueue.Add "StartGracieVideo","StartGracieVideo",81,100,0,0,0,False
End Sub

Sub StopGracieGauntlet (Enable)
	if Enable Then PlaySound "vo_Gracie_End", 0 , fCalloutVolume
    StopSKFlashers
    SkullLight002.state = 0
	GracieGauntletTimer.Enabled = False
	debug.print "Stop Gracie Gauntlet: " &Gametime
	ResetGracieCount
	bGracieGauntlet = False
	CheckBackgroundVideo "Stop Gracie Gauntlet"
	HideGracieOverlay
	SewerTimer.Enabled = False
	ResetSewerTime
	DisplaySewerTime
	'PlayModeMusic

End Sub

Sub GracieGauntletTimer_Timer()
	StopGracieGauntlet True
End Sub


