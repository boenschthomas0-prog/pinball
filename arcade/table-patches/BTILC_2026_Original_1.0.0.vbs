'*
'*        Ensures we are using PuP Version 1.5 or later
'*      Else will exit table
'*
'**********************************************************
Function CompareVersion(v1, v2)
    Dim a1, a2, i

    a1 = Split(v1, ".")
    a2 = Split(v2, ".")

    ' Ensure 4 parts each (pad with zeros if needed)
    ReDim Preserve a1(3)
    ReDim Preserve a2(3)

    For i = 0 To 3
        If CInt(a1(i)) < CInt(a2(i)) Then
            CompareVersion = -1
            Exit Function
        ElseIf CInt(a1(i)) > CInt(a2(i)) Then
            CompareVersion = 1
            Exit Function
        End If
    Next
    CompareVersion = 0
End Function

