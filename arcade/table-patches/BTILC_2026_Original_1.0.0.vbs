'========================================================

'*********************
' GLOBAL VARIABLES
'*********************

Dim SpinStep
Dim SpinLoops
Dim SpinMaxLoops
Dim SpinDirection
Dim SpinPhase
Dim PulseCount
Dim PulseMax
Dim PulseState
Dim Flash4BeaconEnabled
Dim Flash4BeaconStep

'*********************
' INTERNAL ROUTER
'*********************

Sub CallFlasherTimer(nr)
	Select Case nr
		Case 1: FlasherFlash1_Timer
		Case 2: FlasherFlash2_Timer
		Case 3: FlasherFlash3_Timer
		Case 4: FlasherFlash4_Timer
	End Select
End Sub

Sub ForceAllFlashersOff()
	Dim i
	For i = 1 To 4
		ObjTargetLevel(i) = 0
		CallFlasherTimer i
	Next
End Sub


'========================================================
' START SPIN (Clockwise → Counterclockwise)
'========================================================

Sub StartSpinBothDirections(loopsPerDirection)

	SpinStep = 1
	SpinDirection = 1      ' 1 = clockwise
	SpinLoops = 0
	SpinMaxLoops = loopsPerDirection
	SpinPhase = 0          ' 0 = forward, 1 = reversed

	PulsingTimer.Enabled = True

End Sub


'========================================================
' TIMER
'========================================================

Sub PulsingTimer_Timer()

	ForceAllFlashersOff

	ObjTargetLevel(SpinStep) = 1
	CallFlasherTimer SpinStep

	SpinStep = SpinStep + SpinDirection

	If SpinStep > 4 Then
		SpinStep = 1
		SpinLoops = SpinLoops + 1
	End If

	If SpinStep < 1 Then
		SpinStep = 4
		SpinLoops = SpinLoops + 1
	End If

	If SpinLoops >= SpinMaxLoops Then

		If SpinPhase = 0 Then
			SpinPhase = 1
			SpinDirection = -1
			SpinLoops = 0
		Else
			PulsingTimer.Enabled = False
			ForceAllFlashersOff
		End If

	End If

End Sub

'========================================================
' ATTRACT FLASHER CONTROL (HOOKS INTO YOUR EXISTING MODE)
'========================================================

Dim AttractFlashStep

Sub StartFlasherAttract()
    AttractFlashStep = 0
    AttractFlasherTimer.Interval = 120
    AttractFlasherTimer.Enabled = True
End Sub

Sub StopFlasherAttract()
    AttractFlasherTimer.Enabled = False
    ForceAllFlashersOff
End Sub

Sub AttractFlasherTimer_Timer()

    If Not bAttractMode Then Exit Sub

    ForceAllFlashersOff

    ' random flicker
    Dim r
    r = Int(Rnd * 4) + 1
    ObjTargetLevel(r) = 1
    CallFlasherTimer r

    ' every so often do your spin effect
    AttractFlashStep = AttractFlashStep + 1
    If AttractFlashStep Mod 25 = 0 Then
        StartSpinBothDirections 2
    End If

End Sub

Sub StartRapidPulseAll(pulses)

    If bAttractMode Then Exit Sub 

    PulseCount = 0
    PulseMax = pulses * 2     
    PulseState = 0

    RapidPulseTimer.Interval = 60   
    RapidPulseTimer.Enabled = True

End Sub

Sub RapidPulseTimer_Timer()

    If PulseState = 0 Then
        ' TURN ALL ON
        ObjTargetLevel(1) = 1
        ObjTargetLevel(2) = 1
        ObjTargetLevel(3) = 1
        ObjTargetLevel(4) = 1

        FlasherFlash1_Timer
        FlasherFlash2_Timer
        FlasherFlash3_Timer
        FlasherFlash4_Timer

        PulseState = 1
    Else
        ' TURN ALL OFF
        ForceAllFlashersOff
        PulseState = 0
    End If

    PulseCount = PulseCount + 1

    If PulseCount >= PulseMax Then
        RapidPulseTimer.Enabled = False
        ForceAllFlashersOff
    End If

End Sub

Sub Flash4(Enabled)

	' FIX: prevent system conflicts (sweep / madness)
	If FlasherSweepActive Or MadnessActive Then Exit Sub

	If Enabled Then
		Flash4BeaconEnabled = True
		Flash4BeaconStep = 0
		Flash4BeaconTimer.Interval = 70
		Flash4BeaconTimer.Enabled = True
	Else
		Flash4BeaconEnabled = False
		Flash4BeaconTimer.Enabled = False
		ObjTargetLevel(4) = 0
		FlasherFlash4_Timer
	End If

	Sound_Flash_Relay Enabled, Flasherbase4

End Sub


Sub Flash4BeaconTimer_Timer()

	If Flash4BeaconEnabled = False Then Exit Sub

	Flash4BeaconStep = Flash4BeaconStep + 1

	If Flash4BeaconStep <= 3 Then
		ObjTargetLevel(4) = 0.2

	ElseIf Flash4BeaconStep <= 6 Then
		ObjTargetLevel(4) = 0.6

	ElseIf Flash4BeaconStep <= 9 Then
		ObjTargetLevel(4) = 1

	ElseIf Flash4BeaconStep <= 12 Then
		ObjTargetLevel(4) = 0.3

	Else
		Flash4BeaconStep = 0
		' FIX: hard reset to prevent glow carryover
		ObjLevel(4) = 0
	End If

	FlasherFlash4_Timer

End Sub


