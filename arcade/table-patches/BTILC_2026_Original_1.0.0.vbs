'========================================
' 🔥 FINAL CORRECTED FLASHER SYSTEM
'========================================

Const LM_TOTAL_FRAMES = 15

Dim LMFrames, SJFrames
Dim Flashers, FlashPos, FlashRunning, FlashType
Dim FlashDelay
Dim GlobalSpeed

' FlashType:
' 0 = LM
' 1 = LMM
' 2 = JACKPOT

Sub InitFlashers()

    Dim i

    GlobalSpeed = 2

    ReDim LMFrames(LM_TOTAL_FRAMES)
    For i = 1 To LM_TOTAL_FRAMES
        LMFrames(i) = "LM_" & i
    Next

    ReDim SJFrames(45)
    For i = 1 To 45
        SJFrames(i) = "SJ_" & i
    Next

    Flashers = Array( _
        LM1, LM2, LM3, LM4, LM5, _
        LMM1, LMM2, LMM3, LMM4, LMM5, _
        LPSJackpot _
    )

    ReDim FlashPos(UBound(Flashers))
    ReDim FlashRunning(UBound(Flashers))
    ReDim FlashType(UBound(Flashers))
    ReDim FlashDelay(UBound(Flashers))

End Sub

'========================================
' START FUNCTIONS
'========================================

Sub StartLM(index)

    PlaySound "LopM_hit"

    FlashRunning(index) = True
    FlashPos(index) = 1
    FlashType(index) = 0
    FlashDelay(index) = GlobalSpeed

    Flashers(index).Visible = True
    Flashers(index).ImageA = LMFrames(1)

End Sub

Sub StartLMM(index)

    PlaySound "LMM_Hit"

    FlashRunning(index) = True
    FlashPos(index) = 1 ' maps to SJ_2
    FlashType(index) = 1
    FlashDelay(index) = 0

    Flashers(index).Visible = True
    Flashers(index).ImageA = SJFrames(2) ' ✅ FIX START BLANK

End Sub

Sub StartLPSJackpot()

    Dim i
    i = 10

    PlaySound "LPSJackpot"

    FlashRunning(i) = True
    FlashPos(i) = 1
    FlashType(i) = 2
    FlashDelay(i) = 0

    Flashers(i).Visible = True
    Flashers(i).ImageA = SJFrames(2)

End Sub

'========================================
' TIMER
'========================================

Sub FlasherTimer_Timer()

    Dim i

    For i = 0 To UBound(Flashers)

        If FlashRunning(i) Then

            FlashDelay(i) = FlashDelay(i) + 1

            If FlashDelay(i) >= GlobalSpeed Then

                FlashDelay(i) = 0

                Select Case FlashType(i)

                    '========================
                    ' LM
                    '========================
                    Case 0
                        If FlashPos(i) <= LM_TOTAL_FRAMES Then
                            Flashers(i).ImageA = LMFrames(FlashPos(i))
                        End If

                        FlashPos(i) = FlashPos(i) + 1

                        If FlashPos(i) > LM_TOTAL_FRAMES Then
                            Flashers(i).Visible = False
                            FlashRunning(i) = False
                        End If

                    '========================
                    ' LMM (SJ_2 → SJ_42 ONLY)
                    '========================
                    Case 1
                        If FlashPos(i) <= 41 Then ' 2 → 42
                            Flashers(i).ImageA = SJFrames(FlashPos(i) + 1)
                        End If

                        FlashPos(i) = FlashPos(i) + 1

                        If FlashPos(i) > 41 Then
                            Flashers(i).Visible = False
                            FlashRunning(i) = False
                        End If

                    '========================
                    ' JACKPOT (same range)
                    '========================
                    Case 2
                        If FlashPos(i) <= 41 Then
                            Flashers(i).ImageA = SJFrames(FlashPos(i) + 1)
                        End If

                        FlashPos(i) = FlashPos(i) + 1

                        If FlashPos(i) > 41 Then
                            Flashers(i).Visible = False
                            FlashRunning(i) = False
                        End If

                End Select

            End If

        End If

    Next

End Sub

'************************
'ROTATING BEACON SYSTEM
'************************

Dim BeaconAngle
Dim sRGBStep, sRGBFactor, sRed

Dim BeaconCurrentSpeed
Dim BeaconMode

Dim BeaconSpeedRamp
Dim BeaconBlinkState
Dim BeaconSpinCount
Dim BeaconBlinkColorMode

Dim BeaconTripleR, BeaconTripleG, BeaconTripleB
Dim BeaconPurpleStrobeTimer

Const BeaconBaseSpeed = 20


'=============================
' BEACON STACK
'=============================

Dim BeaconStack(10)
Dim BeaconStackTop

BeaconStackTop = -1

Sub BeaconPush(mode)
    BeaconStackTop = BeaconStackTop + 1
    BeaconStack(BeaconStackTop) = mode
    BeaconMode = mode
End Sub

Sub BeaconPop()

    If BeaconStackTop >= 0 Then
        BeaconStackTop = BeaconStackTop - 1
    End If

    If BeaconStackTop >= 0 Then
        BeaconMode = BeaconStack(BeaconStackTop)
    Else
        StopBeacon
    End If

End Sub

Sub BeaconClearStack()
    BeaconStackTop = -1
End Sub


'=============================
' START / STOP
'=============================

Sub StartBeacon
	if nPCMod = 0 Then Exit Sub

    BeaconClearStack

    Beacon.Image = "Beacon3"
    
    BeaconLense.Visible = False
    BeaconLense2.Visible = True
    
    Beacon1.Visible = 1
    Beacon1.IntensityScale = 1
    
    FlasherbloomCenter001.Visible = True
    FlasherbloomCenter001.IntensityScale = 1
    FlasherbloomCenter001.Color = Beacon1.Color
    
    BeaconAngle = 210
    BeaconCurrentSpeed = BeaconBaseSpeed
    
    BeaconMode = 0
    BeaconSpeedRamp = 0
    BeaconBlinkState = 1
    BeaconSpinCount = 0
    BeaconBlinkColorMode = 0
    BeaconPurpleStrobeTimer = 0
    
    sRGBStep = 0
    sRGBFactor = 4
    sRed = 0
    
    BeaconTimer.Enabled = True

End Sub


Sub StopBeacon
	if nPCMod = 0 Then Exit Sub

    BeaconClearStack

    BeaconTimer.Enabled = False
    Beacon1.Visible = 0
    FlasherbloomCenter001.Visible = False  
    BeaconLense.Visible = True
    BeaconLense2.Visible = False
    
    BeaconAngle = 210
    Beacon.RotZ = BeaconAngle
    Beacon1.RotZ = BeaconAngle
    
    Beacon.Image = "Beacon2"
    Beacon1.Color = RGB(255,252,224)
    Beacon1.IntensityScale = 1

End Sub


'=============================
' MAIN TIMER
'=============================

Sub BeaconTimer_Timer()
	if nPCMod = 0 Then BeaconTimer.Enabled = 0 : Exit Sub
    Select Case BeaconMode
    
        Case 0
            BeaconCurrentSpeed = BeaconBaseSpeed
            Beacon1.IntensityScale = 1
        
        Case 1
        
            BeaconSpeedRamp = BeaconSpeedRamp + 1
            
            If BeaconSpeedRamp < 40 Then
                BeaconCurrentSpeed = 2 + (BeaconSpeedRamp / 3)
            ElseIf BeaconSpeedRamp < 80 Then
                BeaconCurrentSpeed = 18 - (BeaconSpeedRamp / 3)
            Else
                BeaconSpeedRamp = 0
            End If
            
            Beacon1.IntensityScale = 1
        
        Case 2
        
            BeaconCurrentSpeed = BeaconBaseSpeed
            
            If BeaconBlinkState = 1 Then
                Beacon1.IntensityScale = Beacon1.IntensityScale - 0.08
                If Beacon1.IntensityScale <= 0 Then
                    Beacon1.IntensityScale = 0
                    BeaconBlinkState = -1
                End If
            Else
                Beacon1.IntensityScale = Beacon1.IntensityScale + 0.08
                If Beacon1.IntensityScale >= 1 Then
                    Beacon1.IntensityScale = 1
                    BeaconBlinkState = 1
                End If
            End If

        Case 3
        
            BeaconCurrentSpeed = 30
            
            BeaconSpinCount = BeaconSpinCount + BeaconCurrentSpeed
            
            If BeaconSpinCount >= 360 Then
                BeaconPop
                Exit Sub
            End If

        '========================================
        ' MODE 4 - STROBE SPIN
        '========================================
        Case 4

            BeaconCurrentSpeed = 25

            If BeaconBlinkState = 1 Then
                Beacon1.IntensityScale = 1
                BeaconBlinkState = -1
            Else
                Beacon1.IntensityScale = 0
                BeaconBlinkState = 1
            End If


        '========================================
        ' MODE 7 - RAINBOW SPIN
        '========================================
        Case 7

            BeaconCurrentSpeed = BeaconBaseSpeed

            sRed = (sRed + 5) Mod 255

            Beacon1.Color = RGB( _
                128 + 127 * Sin(sRed * 0.05), _
                128 + 127 * Sin((sRed + 85) * 0.05), _
                128 + 127 * Sin((sRed + 170) * 0.05))

            Beacon1.IntensityScale = 1


        '========================================
        ' MODE 8 - PURPLE STROBE
        '========================================
        Case 8

            BeaconCurrentSpeed = 25
            BeaconPurpleStrobeTimer = BeaconPurpleStrobeTimer + 1

            If BeaconBlinkState = 1 Then
                Beacon1.IntensityScale = 1
                BeaconBlinkState = -1
            Else
                Beacon1.IntensityScale = 0
                BeaconBlinkState = 1
            End If

            Beacon1.Color = RGB(180,0,255)

            If BeaconPurpleStrobeTimer > 20 Then
                BeaconPop
                Exit Sub
            End If


        '========================================
        ' MODE 9 - RED STROBE
        '========================================
        Case 9

            BeaconCurrentSpeed = 25
            BeaconPurpleStrobeTimer = BeaconPurpleStrobeTimer + 1

            If BeaconBlinkState = 1 Then
                Beacon1.IntensityScale = 1
                BeaconBlinkState = -1
            Else
                Beacon1.IntensityScale = 0
                BeaconBlinkState = 1
            End If

            Beacon1.Color = RGB(255,0,0)

            If BeaconPurpleStrobeTimer > 20 Then
                BeaconPop
                Exit Sub
            End If

    End Select


    BeaconAngle = (BeaconAngle + BeaconCurrentSpeed) Mod 360
    
    Beacon.RotZ = BeaconAngle
    Beacon1.RotZ = BeaconAngle


    If BeaconMode = 2 Then
        
        Select Case BeaconBlinkColorMode
        
            Case 1
                Beacon1.Color = RGB(255, sRed / 3, 0)
            
            Case 2
                Beacon1.Color = RGB(255,191,0) 
            
            Case 3
                Beacon1.Color = RGB(0, sRed, 255)
            
            Case 4
                Beacon1.Color = RGB(0, 255, sRed)

            Case 5
                Beacon1.Color = RGB(180,0,255)
            
            Case Else
                Beacon1.Color = RGB(sRed,255,0)
        
        End Select

    ElseIf BeaconMode = 3 Then
        
        Beacon1.Color = RGB(BeaconTripleR,BeaconTripleG,BeaconTripleB)

    ElseIf BeaconMode <> 7 And BeaconMode <> 8 And BeaconMode <> 9 Then
        
        Beacon1.Color = RGB(sRed,255,0)

    End If


    FlasherbloomCenter001.IntensityScale = Beacon1.IntensityScale
    FlasherbloomCenter001.Color = Beacon1.Color

End Sub


