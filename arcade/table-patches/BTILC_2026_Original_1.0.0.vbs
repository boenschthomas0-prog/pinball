Function rndNumNot(min, max, notNum)
    Randomize
    Dim iNum

Do While 1
    iNum = Int((max-min+1)*Rnd+min)
    If iNum <> notNum Then
        Exit Do
    End If 
loop

rndNumNot = iNum ' return values
End Function

