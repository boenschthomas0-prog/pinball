Sub SewerTimer_Timer
	If SewerCountDown > 239 Then
		nSewerMin = 4
		nSewerSec = SewerCountDown mod 60
	Elseif SewerCountDown > 179 Then 
		nSewerMin = 3
		nSewerSec = SewerCountDown mod 60
	Elseif SewerCountDown > 119 Then 
		nSewerMin = 2
		nSewerSec = SewerCountDown mod 60
	Elseif SewerCountDown > 59 Then 
		nSewerMin = 1
		nSewerSec = SewerCountDown mod 60
	Else
		nSewerMin = ""
		nSewerSec = SewerCountDown mod 60
	End If

	DisplaySewerTime
	SewerCountDown = SewerCountDown - 1
	if SewerCountDown < 0 Then StopSewer
End Sub

